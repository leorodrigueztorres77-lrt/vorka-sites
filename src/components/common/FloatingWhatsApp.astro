---
// Capa 1 — botón de WhatsApp flotante persistente en móvil (esquina inferior
// derecha), estándar del skill vertical-web-builder, distinto del CTA de
// Header/Hero: este queda visible todo el recorrido de scroll, no solo al
// inicio. Solo en móvil — en desktop el CTA del header ya está siempre visible.
//
// `bottomOffset` existe para las variantes de restaurante que además usan
// CartBar.astro (barra fija de pedido consolidado): cuando el carrito tiene
// ítems, ocupa el mismo borde inferior, así que esas páginas deben pasar un
// offset mayor para no superponerse.
import { buildWhatsAppLink } from '@/lib/whatsapp';

interface Props {
  phone: string;
  message: string;
  negocioSlug: string;
  bottomOffset?: string;
}

const { phone, message, negocioSlug, bottomOffset = '16px' } = Astro.props;
const href = buildWhatsAppLink({ phone, message, negocioSlug });
---

<a
  class="wa-flotante"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escríbenos por WhatsApp"
  style={`bottom: ${bottomOffset}`}
>
  <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true" fill="#fff">
    <path
      d="M12 2a10 10 0 0 0-8.6 15.06L2 22l5.1-1.34A10 10 0 1 0 12 2Zm0 18.2a8.16 8.16 0 0 1-4.17-1.14l-.3-.18-3.03.8.81-2.95-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.51-6.13c-.25-.12-1.46-.72-1.68-.8-.23-.08-.39-.12-.56.12-.16.25-.64.8-.78.96-.15.16-.29.18-.53.06-.25-.12-1.04-.38-1.99-1.22-.73-.65-1.23-1.46-1.37-1.7-.15-.25-.02-.38.11-.5.11-.11.25-.29.37-.43.13-.15.17-.25.25-.42.08-.16.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.83-.2-.48-.4-.42-.56-.42h-.48c-.16 0-.42.06-.64.31-.22.25-.85.83-.85 2.02 0 1.2.87 2.35.99 2.51.12.16 1.71 2.62 4.15 3.67.58.25 1.03.4 1.38.51.58.18 1.11.16 1.53.1.47-.07 1.46-.6 1.66-1.18.21-.58.21-1.07.15-1.18-.06-.11-.22-.17-.47-.29Z"
    ></path>
  </svg>
</a>

<style>
  .wa-flotante {
    position: fixed;
    right: 16px;
    z-index: 50;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    transition: transform 0.15s ease;
  }

  .wa-flotante:hover {
    transform: scale(1.06);
  }

  @media (min-width: 900px) {
    .wa-flotante {
      display: none;
    }
  }
</style>
