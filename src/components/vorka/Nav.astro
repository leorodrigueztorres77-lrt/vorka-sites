---
// Vorka — Nav (sitio propio de la agencia). No reutiliza Header.astro: ese
// componente es del vertical restaurante (nav Menú/Galería/Ubicación,
// transición transparente pensada para hero de foto a pantalla completa).
// Aquí el fondo es oscuro en toda la página, así que el nav nace ya con
// --color-fondo y solo gana sombra/blur extra al hacer scroll.
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import type { SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;

const navItems = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Portafolio', href: '#portafolio' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header class="nav" data-nav>
  <div class="container nav__inner">
    <a class="nav__marca" href="#inicio">{site.nombre}</a>
    <nav class="nav__links" aria-label="Navegación principal">
      <ul>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
    <div class="nav__cta">
      <WhatsAppButton
        phone={site.telefonoWhatsApp}
        message="Hola Vorka, quiero información"
        negocioSlug={site.negocioSlug}
        label="Hablemos por WhatsApp →"
        variante="primario"
      />
    </div>
    <button class="nav__burger" type="button" aria-label="Abrir menú" aria-expanded="false" data-nav-burger>
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16" /><path d="M4 12h16" /><path d="M4 18h16" /></svg>
    </button>
  </div>
  <nav class="nav__movil" aria-label="Navegación móvil" data-nav-movil hidden>
    <ul>
      {navItems.map((item) => (
        <li><a href={item.href} data-nav-movil-link>{item.label}</a></li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const navs = document.querySelectorAll('[data-nav]');
  if (navs.length) {
    const alActualizar = () => {
      const conScroll = window.scrollY > 40;
      navs.forEach((nav) => nav.classList.toggle('is-scrolled', conScroll));
    };
    alActualizar();
    window.addEventListener('scroll', alActualizar, { passive: true });
  }

  // Menú hamburguesa en mobile.
  const burger = document.querySelector('[data-nav-burger]') as HTMLButtonElement | null;
  const movil = document.querySelector('[data-nav-movil]') as HTMLElement | null;
  if (burger && movil) {
    const alternar = (abrir?: boolean) => {
      const abierto = abrir ?? movil.hidden;
      movil.hidden = !abierto;
      burger.setAttribute('aria-expanded', String(abierto));
      burger.setAttribute('aria-label', abierto ? 'Cerrar menú' : 'Abrir menú');
    };
    burger.addEventListener('click', () => alternar());
    movil.querySelectorAll('[data-nav-movil-link]').forEach((link) =>
      link.addEventListener('click', () => alternar(false)),
    );
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-fondo);
    transition: box-shadow 300ms ease, backdrop-filter 300ms ease;
  }

  .nav.is-scrolled {
    background: rgba(26, 26, 26, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--shadow-elevar);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .nav__marca {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-lg);
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--color-texto);
  }

  .nav__links ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__links a {
    text-decoration: none;
    color: var(--color-texto);
    font-weight: 500;
    font-size: var(--t-base);
    opacity: 0.85;
    transition: opacity 200ms ease;
  }

  .nav__links a:hover {
    opacity: 1;
  }

  .nav__burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: var(--r-sm);
    background: transparent;
    color: var(--color-texto);
    cursor: pointer;
  }

  .nav__movil {
    border-top: 1px solid var(--border-subtle);
    background: var(--color-fondo);
  }

  .nav__movil ul {
    display: flex;
    flex-direction: column;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 12px 24px 16px;
  }

  .nav__movil a {
    display: block;
    padding: 12px 0;
    text-decoration: none;
    color: var(--color-texto);
    font-family: var(--font-texto);
    font-weight: 500;
    font-size: var(--t-base);
  }

  @media (max-width: 720px) {
    .nav__links {
      display: none;
    }

    .nav__cta {
      display: none;
    }

    .nav__burger {
      display: inline-flex;
    }
  }

  @media (min-width: 721px) {
    .nav__movil {
      display: none !important;
    }
  }
</style>
