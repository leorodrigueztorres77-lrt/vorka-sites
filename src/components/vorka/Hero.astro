---
// Vorka — Hero (sitio propio de la agencia). Centrado, fondo oscuro con
// degradado sutil hacia --color-fondo-alterno (regla de profundidad visual
// #2, CLAUDE.md: bloque de color con peso, no plano). CTA único de WhatsApp
// como acción principal (misma jerarquía de CTA que el resto de Capa 1) +
// link secundario de scroll a Portafolio, sin competir en peso visual.
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import type { SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__contenido">
      <span class="hero__badge reveal">Agencia digital · Ecuador</span>
      <h1 class="hero__titulo reveal">
        Tu negocio merece<br />
        <span class="hero__acento">una web que venda.</span>
      </h1>
      <p class="hero__sub reveal">
        La construimos en días, no en meses, y la conectamos con
        automatización de ventas por WhatsApp.
      </p>
      <div class="hero__cta reveal">
        <WhatsAppButton
          phone={site.telefonoWhatsApp}
          message="Hola Vorka, quiero información"
          negocioSlug={site.negocioSlug}
          label="Hablemos por WhatsApp →"
          variante="primario"
        />
        <a class="hero__cta-secundario" href="#portafolio">Ver ejemplos →</a>
      </div>
      <ul class="hero__proof reveal" aria-label="Garantías de servicio">
        <li><span class="hero__proof-check" aria-hidden="true">✓</span> Respuesta en menos de 2 horas</li>
        <li><span class="hero__proof-check" aria-hidden="true">✓</span> Web lista en 5–7 días</li>
        <li><span class="hero__proof-check" aria-hidden="true">✓</span> Sin contratos largos</li>
      </ul>
    </div>

    <!-- Mockup NEUTRO de web mobile-first (decisión de Leo 2026-07: sin
         rubro específico para no encasillar a Vorka — reemplaza la captura
         del demo El Fogón). Generado con IA (Nano Banana 2 vía fal.ai) con
         la paleta de Vorka; regenerar con scripts/fal-mockup-vorka.mjs de
         SiteWise+ si cambia la identidad. -->
    <div class="hero__mockup reveal--scale" aria-hidden="false">
      <div class="hero__telefono">
        <span class="hero__telefono-notch" aria-hidden="true"></span>
        <img
          src="/images/vorka/mockup-negocio-movil.webp"
          alt="Web profesional mobile-first para tu negocio — Vorka"
          width="320"
          height="574"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 96px;
    padding-bottom: 96px;
    background: linear-gradient(180deg, var(--color-fondo) 0%, var(--color-fondo-alterno) 100%);
    text-align: center;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .hero__contenido {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    max-width: 760px;
  }

  .hero__mockup {
    display: flex;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero__telefono {
    /* 40px: bezel de teléfono, geometría de dispositivo físico — no forma
       parte de la escala r-sm/r-md/r-full (ver nota en index.astro). */
    position: relative;
    width: 264px;
    padding: 12px;
    border-radius: 40px;
    background: #0d0d0d;
    border: 1px solid var(--border-default);
    box-shadow: var(--accent-glow);
  }

  .hero__telefono-notch {
    position: absolute;
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
    width: 88px;
    height: 8px;
    border-radius: var(--r-full);
    background: var(--border-default);
    z-index: 1;
  }

  .hero__telefono img {
    /* 28px: bezel interior, misma excepción que .hero__telefono arriba. */
    display: block;
    width: 100%;
    height: auto;
    border-radius: 28px;
  }

  @media (min-width: 961px) {
    .hero__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }

    .hero__contenido {
      align-items: flex-start;
      max-width: 620px;
    }

    .hero__cta {
      justify-content: flex-start;
    }

    .hero__proof {
      justify-content: flex-start;
    }
  }

  .hero__badge {
    display: inline-block;
    padding: 8px 16px;
    border: 1px solid var(--color-primario);
    border-radius: var(--r-full);
    color: var(--color-primario);
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .hero__titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-display);
    line-height: 1.1;
    color: var(--color-texto);
    margin: 0;
  }

  .hero__acento {
    color: var(--color-primario);
  }

  .hero__sub {
    font-family: var(--font-texto);
    font-size: var(--t-md);
    line-height: 1.7;
    color: var(--color-gris);
    max-width: 560px;
    margin: 0;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 8px;
  }

  .hero__cta-secundario {
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-texto);
    text-decoration: none;
    opacity: 0.75;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 200ms ease;
  }

  .hero__cta-secundario:hover {
    opacity: 1;
  }

  .hero__proof {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 24px;
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
  }

  .hero__proof li {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    color: var(--color-gris);
  }

  .hero__proof-check {
    color: var(--color-primario);
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 64px;
      padding-bottom: 64px;
    }
  }
</style>
