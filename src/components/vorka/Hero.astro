---
// Vorka — Hero (sitio propio de la agencia). Centrado, fondo oscuro con
// degradado sutil hacia --color-fondo-alterno (regla de profundidad visual
// #2, CLAUDE.md: bloque de color con peso, no plano). CTA único de WhatsApp
// como acción principal (misma jerarquía de CTA que el resto de Capa 1) +
// link secundario de scroll a Portafolio, sin competir en peso visual.
//
// Fase 2 (rediseño 2026-07) — fix de animación: el badge y el <h1> NO llevan
// la clase .reveal del estándar de Capa 1. Ese fade (opacity 0 → 1, gateado
// por el IntersectionObserver de BaseLayout) retrasa el primer pintado del
// texto más grande del hero — justo el candidato a LCP más probable de esta
// página — hasta que JS corre y el observer dispara. El resto del contenido
// (subtítulo, CTA, proof list) sí conserva el fade: no son candidatos a LCP
// y el retraso ahí es puramente cosmético.
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import type { SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__contenido">
      <span class="hero__badge">Agencia digital · Ecuador</span>
      <h1 class="hero__titulo">
        Tu negocio merece<br />
        <span class="hero__acento">una web que venda.</span>
      </h1>
      <p class="hero__sub reveal">
        La construimos en días, no en meses, y la conectamos con
        automatización de ventas por WhatsApp.
      </p>
      <div class="hero__cta reveal">
        <WhatsAppButton
          phone={site.telefonoWhatsApp}
          message="Hola Vorka, quiero información"
          negocioSlug={site.negocioSlug}
          label="Hablemos por WhatsApp →"
          variante="primario"
        />
        <a class="hero__cta-secundario" href="#portafolio">Ver ejemplos →</a>
      </div>
      <ul class="hero__proof reveal" aria-label="Garantías de servicio">
        <li><span class="hero__proof-check" aria-hidden="true">✓</span> Respuesta en menos de 2 horas</li>
        <li><span class="hero__proof-check" aria-hidden="true">✓</span> Web lista en 5–7 días</li>
        <li><span class="hero__proof-check" aria-hidden="true">✓</span> Sin contratos largos</li>
      </ul>
    </div>

    <!-- Composición de 2 dispositivos, 100% HTML/CSS (Fase 2 del rediseño
         2026-07): sustituye el mockup generado con IA (frágil, no
         reproducible — el script fal-mockup-vorka.mjs nunca llegó a existir
         en el repo) por un wireframe neutro de web mobile-first (sin rubro
         específico, misma decisión de Leo de no encasillar a Vorka) más una
         tarjeta de chat de WhatsApp simulada superpuesta. Al ser DOM/CSS
         puro (cero bytes de imagen, cero decode) es el candidato a LCP más
         liviano posible para el hero — por eso NO lleva `reveal--scale`:
         envolverlo en el fade/scale de Capa 1 retrasaría su primer pintado
         hasta que el IntersectionObserver corra, justo el error que tenía
         la versión anterior con la imagen. -->
    <div class="hero__mockup" aria-hidden="true">
      <div class="hero__telefono">
        <span class="hero__telefono-notch"></span>
        <div class="hero__pantalla">
          <div class="hero__pantalla-nav"></div>
          <div class="hero__pantalla-hero"></div>
          <span class="hero__pantalla-cta">Pedir por WhatsApp</span>
          <div class="hero__pantalla-fila"></div>
          <div class="hero__pantalla-fila"></div>
          <div class="hero__pantalla-fila hero__pantalla-fila--corta"></div>
        </div>
      </div>

      <div class="hero__chat">
        <div class="hero__chat-cabecera">
          <span class="hero__chat-avatar"></span>
          <div class="hero__chat-info">
            <span class="hero__chat-nombre">Tu negocio</span>
            <span class="hero__chat-estado">en línea</span>
          </div>
        </div>
        <p class="hero__chat-burbuja hero__chat-burbuja--entrante">Hola! Vi tu web, quiero hacer un pedido</p>
        <p class="hero__chat-burbuja hero__chat-burbuja--saliente">¡Con gusto! Dime qué necesitas y lo confirmamos ✅</p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 96px;
    padding-bottom: 96px;
    background: linear-gradient(180deg, var(--color-fondo) 0%, var(--color-fondo-alterno) 100%);
    text-align: center;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .hero__contenido {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    max-width: 760px;
  }

  .hero__mockup {
    position: relative;
    display: flex;
    justify-content: center;
    flex-shrink: 0;
  }

  .hero__telefono {
    /* 40px: bezel de teléfono, geometría de dispositivo físico — no forma
       parte de la escala r-sm/r-md/r-full (ver nota en index.astro). */
    position: relative;
    width: 264px;
    padding: 12px;
    border-radius: 40px;
    background: #0d0d0d;
    border: 1px solid var(--border-default);
    box-shadow: var(--accent-glow);
  }

  .hero__telefono-notch {
    position: absolute;
    top: 22px;
    left: 50%;
    transform: translateX(-50%);
    width: 88px;
    height: 8px;
    border-radius: var(--r-full);
    background: var(--border-default);
    z-index: 1;
  }

  .hero__pantalla {
    /* 28px: bezel interior de la pantalla, misma excepción documentada que
       .hero__telefono arriba — geometría de dispositivo, no forma parte de
       la escala r-sm/r-md/r-full. Fondo blanco a propósito: representa una
       web de cliente (tema claro), en contraste con el fondo oscuro de
       Vorka alrededor. */
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    aspect-ratio: 240 / 430;
    padding: 16px 12px;
    border-radius: 28px;
    background: #ffffff;
    overflow: hidden;
  }

  .hero__pantalla-nav {
    width: 56px;
    height: 10px;
    border-radius: 4px;
    background: #e5e5e5;
  }

  .hero__pantalla-hero {
    height: 96px;
    border-radius: var(--r-sm);
    background: linear-gradient(135deg, #e9e9e9, #d6d6d6);
  }

  .hero__pantalla-cta {
    align-self: flex-start;
    padding: 8px 20px;
    border-radius: var(--r-full);
    background: var(--color-primario);
    color: #ffffff;
    /* 11px: texto decorativo en miniatura dentro de un wireframe a escala
       de teléfono — no es contenido real, cae fuera de la escala t-xs..t-2xl. */
    font-family: var(--font-texto);
    font-size: 11px;
    font-weight: 600;
  }

  .hero__pantalla-fila {
    height: 14px;
    width: 100%;
    border-radius: 4px;
    background: #eeeeee;
  }

  .hero__pantalla-fila--corta {
    width: 60%;
  }

  .hero__chat {
    position: absolute;
    right: -20px;
    bottom: 56px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 176px;
    padding: 12px;
    border-radius: var(--r-md);
    background: #ffffff;
    box-shadow: var(--shadow-elevar);
  }

  .hero__chat-cabecera {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 8px;
    border-bottom: 1px solid #ececec;
  }

  .hero__chat-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primario);
    flex-shrink: 0;
  }

  .hero__chat-info {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }

  .hero__chat-nombre {
    font-family: var(--font-texto);
    font-size: 11px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .hero__chat-estado {
    /* #25d366: verde "en línea" oficial de la UI de WhatsApp — igual que en
       WhatsAppFlotante.astro, no themeable. */
    font-family: var(--font-texto);
    font-size: 10px;
    color: #25d366;
  }

  .hero__chat-burbuja {
    margin: 0;
    padding: 6px 10px;
    max-width: 88%;
    border-radius: 10px;
    font-family: var(--font-texto);
    font-size: 11px;
    line-height: 1.4;
    color: #1a1a1a;
  }

  .hero__chat-burbuja--entrante {
    align-self: flex-start;
    background: #f0f0f0;
    border-bottom-left-radius: 2px;
  }

  .hero__chat-burbuja--saliente {
    /* #dcf8c6: verde de burbuja saliente de la UI real de WhatsApp —
       excepción de marca, no forma parte de la paleta temática de Vorka. */
    align-self: flex-end;
    background: #dcf8c6;
    border-bottom-right-radius: 2px;
  }

  @media (max-width: 720px) {
    .hero__chat {
      width: 144px;
      right: -12px;
      bottom: 40px;
    }
  }

  @media (min-width: 961px) {
    .hero__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }

    .hero__contenido {
      align-items: flex-start;
      max-width: 620px;
    }

    .hero__cta {
      justify-content: flex-start;
    }

    .hero__proof {
      justify-content: flex-start;
    }
  }

  .hero__badge {
    display: inline-block;
    padding: 8px 16px;
    border: 1px solid var(--color-primario);
    border-radius: var(--r-full);
    color: var(--color-primario);
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .hero__titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-display);
    line-height: 1.1;
    color: var(--color-texto);
    margin: 0;
  }

  .hero__acento {
    color: var(--color-primario);
  }

  .hero__sub {
    font-family: var(--font-texto);
    font-size: var(--t-md);
    line-height: 1.7;
    color: var(--color-gris);
    max-width: 560px;
    margin: 0;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 8px;
  }

  .hero__cta-secundario {
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-texto);
    text-decoration: none;
    opacity: 0.75;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity 200ms ease;
  }

  .hero__cta-secundario:hover {
    opacity: 1;
  }

  .hero__proof {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 24px;
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
  }

  .hero__proof li {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    color: var(--color-gris);
  }

  .hero__proof-check {
    color: var(--color-primario);
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 64px;
      padding-bottom: 64px;
    }
  }
</style>
