---
// Vorka — Portafolio (spec GTM de Leo 2026-07, Fase 7). 3 proyectos reales de
// Capa 3 con badge de tipo y ciudad. Sin capturas de pantalla todavía (cada
// tarjeta usa el degradado real de la marca del cliente, ver brandkit.*.ts) —
// las capturas reales de pantalla completa quedan para Fase 2. Incluye ya un
// vertical no-restaurante (Estetic Dent, salud) para romper la percepción de
// "solo restaurantes" (resuelve la NOTA GTM PENDIENTE anterior).
import { buildWhatsAppLink } from '@/lib/whatsapp';
import { siteConfigVorka } from '@/data/site.vorka';

const waHref = buildWhatsAppLink({
  phone: siteConfigVorka.telefonoWhatsApp,
  message: 'Hola Vorka, no vi mi tipo de negocio en los ejemplos y quiero información',
  negocioSlug: siteConfigVorka.negocioSlug,
});

const proyectos = [
  {
    nombre: 'El Fogón Ecuatoriano',
    vertical: 'Restaurante',
    ciudad: 'Conocoto, Quito',
    descripcion: 'Comida ecuatoriana tradicional en Conocoto, Quito.',
    href: '/demo-el-fogon-ecuatoriano/',
    colorInicio: '#C1440E',
    colorFin: '#9B3510',
  },
  {
    nombre: 'Shangrila',
    vertical: 'Restaurante',
    // TODO CONFIRMAR con Leo la ciudad real del demo Shangrila.
    ciudad: 'Quito',
    descripcion: 'Parrilla casual y enérgica.',
    href: '/demo-shangrila/',
    colorInicio: '#E85D2C',
    colorFin: '#C2410C',
  },
  {
    nombre: 'Estetic Dent',
    vertical: 'Salud',
    ciudad: 'Quitumbe, Quito',
    descripcion: 'Consultorio odontológico moderno en el sur de Quito.',
    href: '/demo-esteticdent/',
    colorInicio: '#122B54',
    colorFin: '#0B1A38',
  },
];
---

<section class="portafolio section section--alterno" id="portafolio">
  <div class="container">
    <p class="portafolio__eyebrow reveal">Ejemplos reales</p>
    <h2 class="section-title reveal">Así se ve un negocio como el tuyo con Vorka</h2>
    <div class="portafolio__grid">
      {proyectos.map((proyecto) => (
        <a class="proyecto reveal--scale" href={proyecto.href} target="_blank" rel="noopener noreferrer">
          <div
            class="proyecto__portada"
            style={`background: linear-gradient(135deg, ${proyecto.colorInicio}, ${proyecto.colorFin});`}
          >
            <span class="proyecto__demo-badge">Demo</span>
            <span class="proyecto__portada-nombre">{proyecto.nombre}</span>
          </div>
          <div class="proyecto__info">
            <span class="proyecto__vertical">{proyecto.vertical} · {proyecto.ciudad}</span>
            <h3 class="proyecto__titulo">{proyecto.nombre}</h3>
            <p class="proyecto__desc">{proyecto.descripcion}</p>
            <span class="proyecto__cta">Ver demo →</span>
          </div>
        </a>
      ))}
    </div>
    <p class="portafolio__cta-pie reveal">
      <a href={waHref} target="_blank" rel="noopener noreferrer">
        ¿No ves tu tipo de negocio? Hablemos →
      </a>
    </p>
  </div>
</section>

<style>
  .portafolio__eyebrow {
    font-family: var(--font-texto);
    font-weight: 600;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primario);
    margin: 0 0 12px;
  }

  .portafolio__cta-pie {
    margin: 40px 0 0;
    text-align: center;
  }

  .portafolio__cta-pie a {
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-primario);
    text-decoration: none;
  }

  .portafolio__cta-pie a:hover {
    text-decoration: underline;
  }

  .portafolio__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .proyecto {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--color-fondo);
    box-shadow: var(--shadow-elevar);
    text-decoration: none;
    transition: transform 250ms ease;
  }

  .proyecto:hover {
    transform: translateY(-4px);
  }

  .proyecto__portada {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 220px;
  }

  .proyecto__demo-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 3px 12px;
    border: 1px solid #666666;
    border-radius: var(--r-full);
    background: transparent;
    color: #666666;
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .proyecto__portada-nombre {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-weight: 700;
    font-size: var(--t-xl);
    color: #ffffff;
    text-align: center;
    padding: 0 24px;
  }

  .proyecto__info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
  }

  .proyecto__vertical {
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primario);
  }

  .proyecto__titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-md);
    color: var(--color-texto);
    margin: 0;
  }

  .proyecto__desc {
    font-family: var(--font-texto);
    font-size: var(--t-base);
    line-height: 1.7;
    color: var(--color-gris);
    margin: 0;
  }

  .proyecto__cta {
    margin-top: 8px;
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-texto);
  }

  @media (max-width: 960px) {
    .portafolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .portafolio__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
