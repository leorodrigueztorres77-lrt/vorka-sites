---
// Vorka — Portafolio (spec GTM de Leo 2026-07, Fase 7; capturas reales
// añadidas en Fase 2 del rediseño 2026-07). 3 proyectos reales de Capa 3 con
// badge de tipo y ciudad. Cada tarjeta muestra la captura de página completa
// real del demo (390px, ver scripts/capture-demo-screenshots.mjs) dentro de
// un browser-frame oscuro; en hover/focus la captura hace scroll vertical
// para revelar el sitio completo (truco de translateY con unidades de
// container query, sin JS — ver estilos de .proyecto__viewport). Incluye ya
// un vertical no-restaurante (Estetic Dent, salud) para romper la percepción
// de "solo restaurantes".
import { buildWhatsAppLink } from '@/lib/whatsapp';
import { siteConfigVorka } from '@/data/site.vorka';

const waHref = buildWhatsAppLink({
  phone: siteConfigVorka.telefonoWhatsApp,
  message: 'Hola Vorka, no vi mi tipo de negocio en los ejemplos y quiero información',
  negocioSlug: siteConfigVorka.negocioSlug,
});

const proyectos = [
  {
    nombre: 'El Fogón Ecuatoriano',
    vertical: 'Restaurante',
    ciudad: 'Conocoto, Quito',
    descripcion: 'Comida ecuatoriana tradicional en Conocoto, Quito.',
    href: '/demo-el-fogon-ecuatoriano/',
    captura: '/images/vorka/portafolio/el-fogon-ecuatoriano.webp',
    capturaAlto: 11430,
  },
  {
    nombre: 'Shangrila',
    vertical: 'Restaurante',
    // TODO CONFIRMAR con Leo la ciudad real del demo Shangrila.
    ciudad: 'Quito',
    descripcion: 'Parrilla casual y enérgica.',
    href: '/demo-shangrila/',
    captura: '/images/vorka/portafolio/shangrila.webp',
    capturaAlto: 4116,
  },
  {
    nombre: 'Estetic Dent',
    vertical: 'Salud',
    ciudad: 'Quitumbe, Quito',
    descripcion: 'Consultorio odontológico moderno en el sur de Quito.',
    href: '/demo-esteticdent/',
    captura: '/images/vorka/portafolio/esteticdent.webp',
    capturaAlto: 8999,
  },
];
---

<section class="portafolio section section--alterno" id="portafolio">
  <div class="container">
    <p class="portafolio__eyebrow reveal">Ejemplos reales</p>
    <h2 class="section-title reveal">Así se ve un negocio como el tuyo con Vorka</h2>
    <div class="portafolio__grid">
      {proyectos.map((proyecto) => (
        <a class="proyecto reveal--scale" href={proyecto.href} target="_blank" rel="noopener noreferrer">
          <div class="proyecto__navegador">
            <span class="proyecto__demo-badge">Demo</span>
            <div class="proyecto__navegador-barra" aria-hidden="true">
              <span class="proyecto__dot proyecto__dot--rojo"></span>
              <span class="proyecto__dot proyecto__dot--amarillo"></span>
              <span class="proyecto__dot proyecto__dot--verde"></span>
              <span class="proyecto__navegador-url">vorka.ec{proyecto.href}</span>
            </div>
            <div class="proyecto__viewport">
              <img
                src={proyecto.captura}
                alt={`Captura real de la web de ${proyecto.nombre}`}
                width="390"
                height={proyecto.capturaAlto}
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
          <div class="proyecto__info">
            <span class="proyecto__vertical">{proyecto.vertical} · {proyecto.ciudad}</span>
            <h3 class="proyecto__titulo">{proyecto.nombre}</h3>
            <p class="proyecto__desc">{proyecto.descripcion}</p>
            <span class="proyecto__cta">Ver demo →</span>
          </div>
        </a>
      ))}
    </div>
    <p class="portafolio__cta-pie reveal">
      <a href={waHref} target="_blank" rel="noopener noreferrer">
        ¿No ves tu tipo de negocio? Hablemos →
      </a>
    </p>
  </div>
</section>

<style>
  .portafolio__eyebrow {
    font-family: var(--font-texto);
    font-weight: 600;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primario);
    margin: 0 0 12px;
  }

  .portafolio__cta-pie {
    margin: 40px 0 0;
    text-align: center;
  }

  .portafolio__cta-pie a {
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-primario);
    text-decoration: none;
  }

  .portafolio__cta-pie a:hover {
    text-decoration: underline;
  }

  .portafolio__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .proyecto {
    display: flex;
    flex-direction: column;
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--color-fondo);
    box-shadow: var(--shadow-elevar);
    text-decoration: none;
    transition: transform 250ms ease;
  }

  .proyecto:hover {
    transform: translateY(-4px);
  }

  .proyecto__navegador {
    position: relative;
    background: #0d0d0d;
  }

  .proyecto__demo-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 1;
    padding: 3px 12px;
    border: 1px solid #666666;
    border-radius: var(--r-full);
    background: rgba(13, 13, 13, 0.85);
    color: #666666;
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .proyecto__navegador-barra {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    padding: 0 16px;
    background: var(--bg-1);
    border-bottom: 1px solid var(--border-subtle);
  }

  .proyecto__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Colores de semáforo de ventana de navegador — convención universal de
     macOS/Chrome, no forman parte de la paleta temática de Vorka. */
  .proyecto__dot--rojo {
    background: #ff5f56;
  }

  .proyecto__dot--amarillo {
    background: #f5a623;
  }

  .proyecto__dot--verde {
    background: #27c93f;
  }

  .proyecto__navegador-url {
    margin-left: 8px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    color: var(--color-gris);
  }

  .proyecto__viewport {
    /* container-type: size habilita las unidades cqh de abajo — así el
       translateY de hover se calcula 100% en JS-free CSS puro a partir del
       alto real de la captura vs. el alto fijo de este viewport. */
    container-type: size;
    height: 360px;
    overflow: hidden;
    background: var(--bg-1);
  }

  .proyecto__viewport img {
    display: block;
    width: 100%;
    height: auto;
    transform: translateY(0);
    transition: transform 6s cubic-bezier(0.25, 0.1, 0.25, 1);
  }

  .proyecto:hover .proyecto__viewport img,
  .proyecto:focus-visible .proyecto__viewport img {
    transform: translateY(calc(-100% + 100cqh));
  }

  @media (prefers-reduced-motion: reduce) {
    .proyecto__viewport img {
      transition: none;
    }

    .proyecto:hover .proyecto__viewport img,
    .proyecto:focus-visible .proyecto__viewport img {
      transform: translateY(0);
    }
  }

  .proyecto__info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
  }

  .proyecto__vertical {
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primario);
  }

  .proyecto__titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-md);
    color: var(--color-texto);
    margin: 0;
  }

  .proyecto__desc {
    font-family: var(--font-texto);
    font-size: var(--t-base);
    line-height: 1.7;
    color: var(--color-gris);
    margin: 0;
  }

  .proyecto__cta {
    margin-top: 8px;
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-texto);
  }

  @media (max-width: 960px) {
    .portafolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .portafolio__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
