---
// Vorka — Anchor de valor (spec GTM de Leo 2026-07, Fase 6): comparativa
// freelance vs Vorka que ancla el precio como inversión. En mobile la tabla
// colapsa a cards apiladas (NUNCA tabla horizontal con scroll, regla de la
// spec). Ordercash mantiene el framing del sistema, no promesa de fecha.
import { buildWhatsAppLink } from '@/lib/whatsapp';
import type { SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;

const href = buildWhatsAppLink({
  phone: site.telefonoWhatsApp,
  message: 'Hola Vorka, quiero información para mi negocio',
  negocioSlug: site.negocioSlug,
});

const filas = [
  { concepto: 'Tiempo de entrega', freelance: 'semanas o meses, según disponibilidad', vorka: '5–7 días' },
  { concepto: 'Precio', freelance: 'presupuestos variables, a menudo sin mantenimiento incluido', vorka: 'Desde $350' },
  { concepto: 'Facturación SRI', freelance: 'No incluida', vorka: 'Automatizada con Ordercash' },
  { concepto: 'Soporte post lanzamiento', freelance: 'Paga extra', vorka: 'Incluido en mantenimiento' },
  { concepto: 'WhatsApp integrado', freelance: 'Configuración manual', vorka: 'Nativo en cada proyecto' },
  { concepto: 'Válido para cualquier negocio', freelance: 'Depende del freelance', vorka: 'Sí' },
];
---

<section class="comparativa section" id="comparativa">
  <div class="container comparativa__inner">
    <h2 class="section-title reveal">¿Por qué no contratar a un freelance?</h2>

    <div class="comparativa__tabla reveal" role="table" aria-label="Comparación entre un freelance típico y Vorka">
      <div class="comparativa__fila comparativa__fila--cabecera" role="row">
        <span role="columnheader"></span>
        <span role="columnheader">Freelance típico</span>
        <span role="columnheader" class="comparativa__col-vorka">Vorka</span>
      </div>
      {filas.map((fila) => (
        <div class="comparativa__fila" role="row">
          <span class="comparativa__concepto" role="rowheader">{fila.concepto}</span>
          <span class="comparativa__valor" role="cell">
            <span class="comparativa__etiqueta" aria-hidden="true">Freelance típico</span>
            {fila.freelance}
          </span>
          <span class="comparativa__valor comparativa__valor--vorka" role="cell">
            <span class="comparativa__etiqueta" aria-hidden="true">Vorka</span>
            {fila.vorka} <span class="comparativa__check" aria-hidden="true">✓</span>
          </span>
        </div>
      ))}
    </div>

    <a class="btn btn--primario reveal" href={href} target="_blank" rel="noopener noreferrer">
      Hablemos por WhatsApp →
    </a>
    <p class="comparativa__subtext reveal">Sin compromiso. Respuesta en menos de 2 horas.</p>
  </div>
</section>

<style>
  .comparativa {
    background: var(--color-fondo);
  }

  .comparativa__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .comparativa__tabla {
    width: 100%;
    max-width: 860px;
    margin: 0 0 40px;
    border: 1px solid var(--border-default);
    border-radius: var(--r-md);
    overflow: hidden;
  }

  .comparativa__fila {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1.2fr;
    gap: 8px;
    padding: 14px 24px;
    align-items: center;
  }

  .comparativa__fila:nth-child(even) {
    background: var(--color-fondo-alterno);
  }

  .comparativa__fila--cabecera {
    background: var(--color-fondo-alterno);
    font-family: var(--font-texto);
    font-weight: 700;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gris);
  }

  .comparativa__col-vorka {
    color: var(--color-primario);
  }

  .comparativa__concepto {
    font-family: var(--font-texto);
    font-weight: 600;
    font-size: var(--t-sm);
    color: var(--color-texto);
  }

  .comparativa__valor {
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    color: var(--color-gris);
  }

  .comparativa__valor--vorka {
    color: var(--color-texto);
    font-weight: 600;
  }

  .comparativa__check {
    color: var(--color-primario);
    font-weight: 700;
  }

  /* Etiquetas solo visibles en el layout apilado de mobile. */
  .comparativa__etiqueta {
    display: none;
  }

  .comparativa__subtext {
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    color: var(--color-gris);
    margin: 12px 0 0;
  }

  @media (max-width: 720px) {
    .comparativa__fila--cabecera {
      display: none;
    }

    .comparativa__fila {
      grid-template-columns: 1fr;
      gap: 6px;
      padding: 20px 24px;
    }

    .comparativa__concepto {
      font-size: var(--t-base);
      margin-bottom: 2px;
    }

    .comparativa__etiqueta {
      display: block;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-gris);
      opacity: 0.7;
    }

    .comparativa__valor--vorka .comparativa__etiqueta {
      color: var(--color-primario);
      opacity: 1;
    }
  }
</style>
