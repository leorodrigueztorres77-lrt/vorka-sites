---
// Vorka — Precios (3 planes, corrección V2 de Leo 2026-07). El ancla visual
// es el plan Profesional (borde --color-primario + badge "Más elegido").
// Los precios provienen del pricing vigente de CLAUDE.md. La IA no se vende
// como tecnología: se traduce en beneficios concretos para el cliente.
import { buildWhatsAppLink } from '@/lib/whatsapp';
import type { SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;

const linkPlan = (plan: string) =>
  buildWhatsAppLink({
    phone: site.telefonoWhatsApp,
    message: `Hola Vorka, quiero mi web con el plan ${plan}`,
    negocioSlug: site.negocioSlug,
  });

const planes = [
  {
    nombre: 'Básica',
    precio: '$350',
    subtitulo: 'Para negocios que necesitan presencia digital hoy',
    baseDe: null,
    incluye: [
      'Web de hasta 5 páginas',
      'Diseño profesional adaptado a tu marca',
      'Botón de WhatsApp con seguimiento',
      'Optimización para Google (SEO local)',
      'Entrega en 3–5 días hábiles',
      '1 ronda de ajustes incluida',
    ],
    mantenimiento: 'Mantenimiento opcional: desde $40/mes',
    cta: 'Quiero mi web →',
    destacado: false,
  },
  {
    nombre: 'Profesional',
    precio: '$500',
    subtitulo: 'Para negocios que quieren destacar y convertir visitas en clientes',
    baseDe: 'Incluye todo lo de Básica, más:',
    incluye: [
      'Galería de fotos optimizada con IA',
      'Copy escrito con IA adaptado a tu negocio y tus clientes',
      'Sección de reseñas y testimonios',
      'Integración con Google Maps',
      'Entrega en 5–7 días hábiles',
      '2 rondas de ajustes incluidas',
    ],
    mantenimiento: 'Mantenimiento opcional: desde $60/mes',
    cta: 'Quiero mi web →',
    destacado: true,
  },
  {
    nombre: 'Premium',
    precio: 'desde $750',
    subtitulo: 'Para negocios que quieren automatizar ventas desde el primer día',
    baseDe: 'Incluye todo lo de Profesional, más:',
    incluye: [
      'Formulario de pedidos listo para automatización por WhatsApp',
      'Campo de RUC/cédula para facturación futura',
      'Sección "producto en movimiento" (video o galería animada)',
      'Coordinación de sesión fotográfica profesional',
      'Entrega en 5–7 días hábiles',
      'Ajustes ilimitados por 30 días',
    ],
    mantenimiento: 'Mantenimiento: desde $80/mes',
    cta: 'Hablemos de tu proyecto →',
    destacado: false,
  },
];
---

<section class="precios section section--alterno" id="precios">
  <div class="container">
    <h2 class="section-title reveal">Tu web lista en días. Sin sorpresas.</h2>
    <p class="precios__sub reveal">Precio fijo, entrega rápida, resultado profesional.</p>

    <div class="precios__grid">
      {planes.map((plan) => (
        <article class={`plan reveal--scale ${plan.destacado ? 'plan--destacado' : ''}`}>
          {plan.destacado && <span class="plan__badge">Más elegido</span>}
          <h3 class="plan__nombre">{plan.nombre}</h3>
          <p class="plan__precio">{plan.precio}</p>
          <p class="plan__subtitulo">{plan.subtitulo}</p>
          {plan.baseDe && <p class="plan__base">{plan.baseDe}</p>}
          <ul class="plan__lista">
            {plan.incluye.map((item) => (
              <li>
                <span class="plan__check" aria-hidden="true">✓</span>
                {item}
              </li>
            ))}
          </ul>
          <p class="plan__mantenimiento">{plan.mantenimiento}</p>
          <a
            class={`btn ${plan.destacado ? 'btn--primario' : 'plan__cta-secundario'}`}
            href={linkPlan(plan.nombre)}
            target="_blank"
            rel="noopener noreferrer"
          >
            {plan.cta}
          </a>
        </article>
      ))}
    </div>

    <p class="precios__nota reveal">
      El mantenimiento mensual incluye hasta 2 cambios de contenido, reporte
      mensual de visitas y soporte por WhatsApp. No es solo hosting.
    </p>
  </div>
</section>

<style>
  .precios__sub {
    font-family: var(--font-texto);
    font-size: var(--t-md);
    color: var(--color-gris);
    text-align: center;
    margin: -24px 0 48px;
  }

  .precios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    align-items: start;
  }

  .plan {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px;
    border-radius: var(--r-md);
    background: var(--color-fondo);
    border: 1px solid var(--border-default);
    box-shadow: var(--shadow-elevar);
  }

  .plan--destacado {
    border: 2px solid var(--color-primario);
  }

  .plan__badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 16px;
    border-radius: var(--r-full);
    background: var(--color-primario);
    color: var(--color-fondo);
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .plan__nombre {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-md);
    color: var(--color-texto);
    margin: 0;
  }

  .plan__precio {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-2xl);
    line-height: 1;
    color: var(--color-primario);
    margin: 0;
  }

  .plan__subtitulo {
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    line-height: 1.6;
    color: var(--color-gris);
    margin: 0 0 4px;
  }

  .plan__base {
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-texto);
    opacity: 0.7;
    margin: 0;
  }

  .plan__lista {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .plan__lista li {
    display: flex;
    gap: 10px;
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    line-height: 1.5;
    color: var(--color-texto);
  }

  .plan__check {
    color: var(--color-primario);
    font-weight: 700;
    flex-shrink: 0;
  }

  .plan__mantenimiento {
    font-family: var(--font-texto);
    font-size: var(--t-xs);
    color: var(--color-gris);
    margin: 8px 0 4px;
  }

  .plan__cta-secundario {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 12px 24px;
    border: 1px solid var(--color-primario);
    border-radius: var(--r-full);
    color: var(--color-primario);
    font-family: var(--font-texto);
    font-weight: 600;
    text-decoration: none;
    transition: background 200ms ease, color 200ms ease;
  }

  .plan__cta-secundario:hover {
    background: var(--color-primario);
    color: var(--color-fondo);
  }

  .precios__nota {
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    color: var(--color-gris);
    text-align: center;
    max-width: 560px;
    margin: 40px auto 0;
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .precios__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .plan--destacado {
      order: -1;
    }
  }
</style>
