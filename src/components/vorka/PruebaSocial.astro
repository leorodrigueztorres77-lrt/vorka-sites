---
// Vorka — Prueba social (spec GTM de Leo 2026-07, Fase 3). REGLA DURA de la
// spec: NUNCA inventar testimonios. Mientras no existan reales, las cards
// llevan la clase `placeholder-testimonio` y texto claramente marcado.
// Pregunta para recolectar testimonios reales (enviar por WhatsApp al
// cliente): "¿Qué problema tenías antes de Vorka y qué cambió después?
// En 2 o 3 líneas." Priorizar tipos de negocio DISTINTOS entre sí para
// demostrar amplitud (restaurante + consultorio + tienda/servicio).
const testimonios = [
  // <!-- REEMPLAZAR CON TESTIMONIO REAL -->
  {
    texto:
      'Aquí irá el testimonio real de un cliente de restaurante, con un resultado concreto de pedidos por WhatsApp.',
    autor: 'Nombre por confirmar',
    rol: 'Dueño de restaurante',
    ciudad: 'Quito',
    placeholder: true,
  },
  // <!-- REEMPLAZAR CON TESTIMONIO REAL -->
  {
    texto:
      'Aquí irá el testimonio real de un consultorio, con un resultado concreto de citas agendadas desde la web.',
    autor: 'Nombre por confirmar',
    rol: 'Consultorio médico o dental',
    ciudad: 'Quito',
    placeholder: true,
  },
  // <!-- REEMPLAZAR CON TESTIMONIO REAL -->
  {
    texto:
      'Aquí irá el testimonio real de una tienda o servicio profesional, para demostrar que Vorka sirve a cualquier negocio.',
    autor: 'Nombre por confirmar',
    rol: 'Tienda o servicio profesional',
    ciudad: 'Ecuador',
    placeholder: true,
  },
];
---

<section class="prueba-social section" id="confianza">
  <div class="container">
    <p class="prueba-social__eyebrow reveal">Negocios que ya confían en Vorka</p>
    <div class="prueba-social__grid">
      {testimonios.map((t) => (
        <figure class={`testimonio reveal--scale ${t.placeholder ? 'placeholder-testimonio' : ''}`}>
          <div class="testimonio__estrellas" aria-label="Calificación 5 de 5">★★★★★</div>
          <blockquote class="testimonio__texto">“{t.texto}”</blockquote>
          <figcaption class="testimonio__autor">
            {t.autor} · {t.rol}, {t.ciudad}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .prueba-social__eyebrow {
    font-family: var(--font-texto);
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primario);
    text-align: center;
    margin: 0 0 32px;
  }

  .prueba-social__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testimonio {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    padding: 28px;
    border-radius: 16px;
    background: var(--color-fondo-alterno);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
  }

  /* Marcado visual sutil mientras sean placeholders — quitar al reemplazar. */
  .placeholder-testimonio {
    opacity: 0.75;
    border: 1px dashed rgba(255, 255, 255, 0.25);
  }

  .testimonio__estrellas {
    color: var(--color-primario);
    font-size: 1rem;
    letter-spacing: 2px;
  }

  .testimonio__texto {
    font-family: var(--font-texto);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-texto);
    margin: 0;
  }

  .testimonio__autor {
    font-family: var(--font-texto);
    font-size: 0.8125rem;
    color: var(--color-gris);
  }

  @media (max-width: 860px) {
    .prueba-social__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
