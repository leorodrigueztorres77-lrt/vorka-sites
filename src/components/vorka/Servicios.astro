---
// Vorka — Servicios (3 tarjetas). La agencia de webs y Ordercash son los dos
// productos reales (ver CLAUDE.md); la tercera tarjeta es el roadmap de
// "Recepcionista de voz con IA" (CLAUDE.md, Roadmap de innovación) — no
// accionable todavía, así que se muestra visualmente apagada (65% opacidad,
// badge de borde gris) y sin CTA para no prometer algo que no existe.
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import type { SiteConfig } from '@/data/types';
import { ORDERCASH_URL } from '@/data/site.vorka';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section class="servicios section" id="servicios">
  <div class="container">
    <h2 class="section-title reveal">Lo que hacemos</h2>
    <div class="servicios__grid">
      <article class="tarjeta reveal--scale">
        <span class="tarjeta__icono" aria-hidden="true">🌐</span>
        <h3 class="tarjeta__titulo">Webs que venden</h3>
        <p class="tarjeta__desc">
          Sitios profesionales para restaurantes y consultorios — mobile-first,
          rápidos y con el botón de WhatsApp como acción principal. Listos en
          días, no en meses.
        </p>
        <a class="tarjeta__cta" href="#portafolio">Ver portafolio →</a>
      </article>

      <article class="tarjeta reveal--scale">
        <span class="tarjeta__icono" aria-hidden="true">💬</span>
        <h3 class="tarjeta__titulo">Ordercash</h3>
        <p class="tarjeta__desc">
          Pedidos, cobro y facturación electrónica SRI, todo por WhatsApp. Tú
          vendes — Ordercash factura, cobra y registra.
        </p>
        <a class="tarjeta__cta" href={ORDERCASH_URL} target="_blank" rel="noopener noreferrer">
          Conoce Ordercash →
        </a>
      </article>

      <article class="tarjeta tarjeta--proximamente reveal--scale">
        <span class="tarjeta__badge">Próximamente</span>
        <span class="tarjeta__icono" aria-hidden="true">🎙️</span>
        <h3 class="tarjeta__titulo">Agentes de voz con IA</h3>
        <p class="tarjeta__desc">
          Un agente que contesta llamadas 24/7 y agenda citas por ti. En
          desarrollo — todavía no disponible para clientes.
        </p>
      </article>
    </div>

    <div class="servicios__cta-final reveal">
      <WhatsAppButton
        phone={site.telefonoWhatsApp}
        message="Hola Vorka, quiero información sobre sus servicios"
        negocioSlug={site.negocioSlug}
        label="Cuéntanos qué necesitas →"
        variante="primario"
      />
    </div>
  </div>
</section>

<style>
  .servicios {
    background: var(--color-fondo);
  }

  .servicios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .tarjeta {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px;
    border-radius: 16px;
    background: var(--color-fondo-alterno);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
  }

  .tarjeta--proximamente {
    opacity: 0.65;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .tarjeta__badge {
    align-self: flex-start;
    padding: 4px 12px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 100px;
    font-family: var(--font-texto);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gris);
  }

  .tarjeta__icono {
    font-size: 2rem;
    line-height: 1;
  }

  .tarjeta__titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--color-texto);
    margin: 0;
  }

  .tarjeta__desc {
    font-family: var(--font-texto);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gris);
    margin: 0;
  }

  .tarjeta__cta {
    margin-top: auto;
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-primario);
    text-decoration: none;
  }

  .tarjeta__cta:hover {
    text-decoration: underline;
  }

  .servicios__cta-final {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  @media (max-width: 960px) {
    .servicios__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
