---
// Vorka — Servicios (3 tarjetas). La agencia de webs y Ordercash son los dos
// productos reales (ver CLAUDE.md); la tercera tarjeta es el roadmap de
// "Agentes de IA para ventas y atención" (texto/chat, no voz — corrección de
// Leo 2026-07) — no accionable todavía, así que se muestra visualmente
// apagada (65% opacidad, badge de borde gris) y sin CTA para no prometer
// algo que no existe. Íconos: Tabler Icons outline inline (sin emojis, por
// tono de marca "Think Smart, Move Fast").
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import type { SiteConfig } from '@/data/types';
import { ORDERCASH_URL } from '@/data/site.vorka';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section class="servicios section" id="servicios">
  <div class="container">
    <h2 class="section-title reveal">Lo que hacemos</h2>
    <div class="servicios__grid">
      <article class="tarjeta reveal--scale">
        <span class="tarjeta__icono" aria-hidden="true">
          <!-- Tabler: world -->
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" /><path d="M3.6 9h16.8" /><path d="M3.6 15h16.8" /><path d="M11.5 3a17 17 0 0 0 0 18" /><path d="M12.5 3a17 17 0 0 1 0 18" /></svg>
        </span>
        <h3 class="tarjeta__titulo">Webs que venden</h3>
        <p class="tarjeta__desc">
          Sitios profesionales para cualquier negocio — mobile-first, rápidos
          y con el botón de WhatsApp como acción principal. Listos en días,
          no en meses.
        </p>
        <a class="tarjeta__cta" href="#portafolio">Ver portafolio →</a>
      </article>

      <article class="tarjeta reveal--scale">
        <span class="tarjeta__icono" aria-hidden="true">
          <!-- Tabler: brand-whatsapp -->
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg>
        </span>
        <h3 class="tarjeta__titulo">Ordercash</h3>
        <p class="tarjeta__desc">
          Pedidos, cobro y facturación electrónica SRI, todo por WhatsApp. Tú
          vendes — Ordercash factura, cobra y registra.
        </p>
        <a class="tarjeta__cta" href={ORDERCASH_URL} target="_blank" rel="noopener noreferrer">
          Conoce Ordercash →
        </a>
      </article>

      <article class="tarjeta tarjeta--proximamente reveal--scale">
        <span class="tarjeta__badge">Próximamente</span>
        <span class="tarjeta__icono" aria-hidden="true">
          <!-- Tabler: cpu -->
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 5m0 1a1 1 0 0 1 1 -1h12a1 1 0 0 1 1 1v12a1 1 0 0 1 -1 1h-12a1 1 0 0 1 -1 -1z" /><path d="M9 9h6v6h-6z" /><path d="M3 10h2" /><path d="M3 14h2" /><path d="M10 3v2" /><path d="M14 3v2" /><path d="M21 10h-2" /><path d="M21 14h-2" /><path d="M10 21v-2" /><path d="M14 21v-2" /></svg>
        </span>
        <h3 class="tarjeta__titulo">Agentes de IA para ventas y atención</h3>
        <p class="tarjeta__desc">
          Automatiza tu atención al cliente y proceso de ventas con agentes
          inteligentes. En desarrollo — todavía no disponible para clientes.
        </p>
      </article>
    </div>

    <div class="servicios__cta-final reveal">
      <WhatsAppButton
        phone={site.telefonoWhatsApp}
        message="Hola Vorka, quiero información sobre sus servicios"
        negocioSlug={site.negocioSlug}
        label="Cuéntanos qué necesitas →"
        variante="primario"
      />
    </div>
  </div>
</section>

<style>
  .servicios {
    background: var(--color-fondo);
  }

  .servicios__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .tarjeta {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px;
    border-radius: 16px;
    background: var(--color-fondo-alterno);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
  }

  .tarjeta--proximamente {
    opacity: 0.65;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .tarjeta__badge {
    align-self: flex-start;
    padding: 4px 12px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 100px;
    font-family: var(--font-texto);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gris);
  }

  .tarjeta__icono {
    display: inline-flex;
    line-height: 1;
    color: var(--color-primario);
  }

  .tarjeta__titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--color-texto);
    margin: 0;
  }

  .tarjeta__desc {
    font-family: var(--font-texto);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gris);
    margin: 0;
  }

  .tarjeta__cta {
    margin-top: auto;
    font-family: var(--font-texto);
    font-weight: 600;
    color: var(--color-primario);
    text-decoration: none;
  }

  .tarjeta__cta:hover {
    text-decoration: underline;
  }

  .servicios__cta-final {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }

  @media (max-width: 960px) {
    .servicios__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
