---
// Vorka — "Cómo funciona" (spec GTM de Leo 2026-07, Fase 4). Reestructura de
// las 3 cards paralelas a un FLUJO de 3 pasos con Ordercash como núcleo del
// sistema. El paso 2 es genérico (pedido, cita o consulta) para cualquier
// negocio. La antigua card "Agentes de IA" baja a badge al pie SIN CTA;
// se mantiene el concepto corregido por Leo (texto/chat, nunca "voz" ni
// "contesta llamadas") y sin la palabra IA en el flujo de Ordercash (regla
// de oro de copy, CLAUDE.md). Íconos: Tabler outline inline, sin emojis.
import type { SiteConfig } from '@/data/types';
import { ORDERCASH_URL } from '@/data/site.vorka';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---

<section class="servicios section" id="servicios">
  <div class="container">
    <p class="servicios__eyebrow reveal">Cómo funciona</p>
    <h2 class="section-title reveal">La web es la puerta. Ordercash es el motor.</h2>

    <ol class="pasos">
      <li class="paso reveal--scale" style="transition-delay:0ms">
        <span class="paso__numero" aria-hidden="true">1</span>
        <span class="paso__icono" aria-hidden="true">
          <!-- Tabler: world -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0" /><path d="M3.6 9h16.8" /><path d="M3.6 15h16.8" /><path d="M11.5 3a17 17 0 0 0 0 18" /><path d="M12.5 3a17 17 0 0 1 0 18" /></svg>
        </span>
        <h3 class="paso__titulo">Tu web profesional</h3>
        <p class="paso__desc">
          Mobile first, con tu información, servicios o productos, y WhatsApp
          como acción principal. Lista en días, no en meses.
        </p>
        <a class="paso__link" href="#portafolio">Ver ejemplos →</a>
      </li>

      <li class="paso reveal--scale" style="transition-delay:100ms">
        <span class="paso__numero" aria-hidden="true">2</span>
        <span class="paso__icono" aria-hidden="true">
          <!-- Tabler: brand-whatsapp -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg>
        </span>
        <h3 class="paso__titulo">Tu cliente contacta por WhatsApp</h3>
        <p class="paso__desc">
          Hace su pedido, reserva su cita o solicita información,
          directamente desde tu web, sin apps adicionales ni fricción.
        </p>
      </li>

      <li class="paso reveal--scale" style="transition-delay:200ms">
        <span class="paso__numero" aria-hidden="true">3</span>
        <span class="paso__icono" aria-hidden="true">
          <!-- Tabler: receipt -->
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 21v-16a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v16l-3 -2l-2 2l-2 -2l-2 2l-2 -2l-3 2" /><path d="M9 7h6" /><path d="M9 11h6" /><path d="M9 15h4" /></svg>
        </span>
        <h3 class="paso__titulo">Ordercash cobra y factura</h3>
        <p class="paso__desc">
          Factura electrónica SRI automática. Cobro integrado. Tú vendes,
          Ordercash hace el resto. Tu web queda lista para conectarse desde
          el día uno.
        </p>
        <a class="paso__link" href={ORDERCASH_URL} target="_blank" rel="noopener noreferrer">
          Conoce Ordercash →
        </a>
      </li>
    </ol>

    <p class="servicios__badge-futuro reveal">
      <span class="servicios__badge-pill">Próximamente</span>
      Agentes inteligentes para ventas y atención al cliente, disponibles 24/7.
    </p>
  </div>
</section>

<style>
  .servicios {
    background: var(--color-fondo);
  }

  .servicios__eyebrow {
    font-family: var(--font-texto);
    font-weight: 600;
    font-size: var(--t-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primario);
    text-align: center;
    margin: 0 0 12px;
  }

  .pasos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: paso;
  }

  .paso {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 32px;
    border-radius: var(--r-md);
    background: var(--color-fondo-alterno);
    box-shadow: var(--shadow-elevar);
  }

  /* Conector visual entre pasos (solo desktop). */
  .paso:not(:last-child)::after {
    content: '→';
    position: absolute;
    right: -26px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-primario);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .paso__numero {
    position: absolute;
    top: 20px;
    right: 24px;
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: 2rem;
    color: rgba(255, 255, 255, 0.12);
    line-height: 1;
  }

  .paso__icono {
    display: inline-flex;
    color: var(--color-acento);
  }

  .paso__titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-md);
    color: var(--color-texto);
    margin: 0;
  }

  .paso__desc {
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    line-height: 1.7;
    color: var(--color-gris);
    margin: 0;
  }

  .paso__link {
    font-family: var(--font-texto);
    font-weight: 600;
    font-size: var(--t-sm);
    color: var(--color-primario);
    text-decoration: none;
    margin-top: auto;
  }

  .paso__link:hover {
    text-decoration: underline;
  }

  .servicios__badge-futuro {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 40px auto 0;
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    color: var(--color-gris);
    text-align: center;
  }

  .servicios__badge-pill {
    padding: 4px 12px;
    border: 1px solid var(--border-default);
    border-radius: var(--r-full);
    font-size: var(--t-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-gris);
    white-space: nowrap;
  }

  @media (max-width: 960px) {
    .pasos {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .paso:not(:last-child)::after {
      content: '↓';
      right: auto;
      left: 50%;
      top: auto;
      bottom: -28px;
      transform: translateX(-50%);
    }
  }
</style>
