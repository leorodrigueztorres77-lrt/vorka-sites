---
// Vorka — Stats. Deliberadamente NO usa cifras de clientes/reseñas fabricadas
// (CLAUDE.md prohíbe inventar datos de reputación/fidelización) — son 4
// hechos verificables, reescritos en clave de beneficio para el cliente
// (corrección de Leo 2026-07: las métricas internas no le importan al dueño
// del negocio).
const stats = [
  { valor: '5–7 días', label: 'Entrega garantizada' },
  { valor: 'Desde $350', label: 'Sin costos ocultos' },
  { valor: 'A tu medida', label: 'Cualquier negocio, cualquier rubro' },
  { valor: '100% WhatsApp', label: 'CTA principal en cada web' },
];
---

<section class="stats section">
  <div class="container">
    <ul class="stats__grid">
      {stats.map((stat) => (
        <li class="stats__item reveal--scale">
          <span class="stats__valor">{stat.valor}</span>
          <span class="stats__label">{stat.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .stats {
    background: var(--color-fondo);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .stats__valor {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: var(--t-2xl);
    color: var(--color-primario);
  }

  .stats__label {
    font-family: var(--font-texto);
    font-size: var(--t-sm);
    color: var(--color-gris);
  }

  @media (max-width: 720px) {
    .stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
