---
// Capa 2 (consultorio) — sección "Sonrisas reales": cards de antes/después
// por tratamiento (spec de densidad visual de Leo, 2026-07-22). Dos imágenes
// lado a lado con etiquetas Antes/Después + nombre del tratamiento.
// Desktop: grid de 3 columnas. Móvil (<768px): carrusel horizontal con
// scroll-snap.
//
// REGLA DE AUTENTICIDAD (CLAUDE.md): en la entrega final publicada, cada par
// debe ser un caso REAL del propio consultorio, de la MISMA persona y con
// consentimiento del paciente — mostrar resultados clínicos de banco de
// fotos como si fueran propios es publicidad engañosa. El componente es
// agnóstico: la responsabilidad de qué fotos se pasan vive en los datos de
// Capa 3 de cada cliente.
//
// Título/intro por defecto y badge "Imagen ilustrativa" (2026-07-23, spec de
// cierre de demo): mientras las fotos sean generadas/de banco (Nivel 2/2.5),
// el nombre de la sección y el badge por card son obligatorios — nunca
// presentar estas imágenes como "reales" sin ese rótulo visible.
import type { ParAntesDespues } from '@/data/types';

interface Props {
  pares: ParAntesDespues[];
  titulo?: string;
  /** 1 línea opcional de contexto bajo el título. */
  intro?: string;
}

const {
  pares,
  titulo = 'Transformaciones que realizamos',
  intro = 'Ejemplos ilustrativos de nuestros tratamientos más solicitados.',
} = Astro.props;
---

{pares.length > 0 && (
  <section id="sonrisas" class="section" aria-labelledby="sonrisas-titulo">
    <div class="container">
      <h2 id="sonrisas-titulo" class="section-title">{titulo}</h2>
      {intro && <p class="antes-despues__intro">{intro}</p>}

      <div class="antes-despues__pista">
        {pares.map((par) => (
          <article class="antes-despues__card reveal--scale">
            <div class="antes-despues__fotos">
              <figure class="antes-despues__figura">
                <img
                  src={par.antes.src}
                  srcset={par.antes.src2x ? `${par.antes.src} 1x, ${par.antes.src2x} 2x` : undefined}
                  alt={par.antes.alt}
                  loading="lazy"
                  width="640"
                  height="640"
                />
                <figcaption class="antes-despues__etiqueta">Antes</figcaption>
              </figure>
              <figure class="antes-despues__figura">
                <img
                  src={par.despues.src}
                  srcset={par.despues.src2x ? `${par.despues.src} 1x, ${par.despues.src2x} 2x` : undefined}
                  alt={par.despues.alt}
                  loading="lazy"
                  width="640"
                  height="640"
                />
                <figcaption class="antes-despues__etiqueta antes-despues__etiqueta--despues">Después</figcaption>
              </figure>
              <span class="antes-despues__badge">Imagen ilustrativa</span>
            </div>
            <p class="antes-despues__tratamiento">{par.tratamiento}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .antes-despues__intro {
    text-align: center;
    max-width: 560px;
    margin: -1rem auto 2rem;
    opacity: 0.8;
  }

  .antes-despues__pista {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .antes-despues__pista {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .antes-despues__card {
    background: var(--color-fondo, #fff);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .antes-despues__fotos {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .antes-despues__badge {
    position: absolute;
    right: 8px;
    bottom: 8px;
    z-index: 1;
    font-size: 12px;
    font-weight: 600;
    line-height: 1;
    padding: 0.35rem 0.6rem;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
  }

  .antes-despues__figura {
    position: relative;
    margin: 0;
  }

  .antes-despues__figura img {
    width: 100%;
    height: auto; /* sin esto, el atributo height del <img> pisa al aspect-ratio */
    aspect-ratio: 1 / 1;
    object-fit: cover;
    /* Regla de profundidad visual #1 (CLAUDE.md): tratamiento de color
       unificado con el resto de fotos del sitio. */
    filter: saturate(1.05) brightness(1.02) contrast(1.03);
  }

  .antes-despues__etiqueta {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--color-primario);
  }

  .antes-despues__etiqueta--despues {
    background: var(--color-acento);
    color: #1a1a1a;
  }

  .antes-despues__tratamiento {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: 1.15rem;
    text-align: center;
    margin: 0;
    padding: 1rem 1.25rem 1.25rem;
  }

  /* Carrusel móvil con scroll-snap (<768px): cards de 85% de ancho, snap al
     centro, sin barra de scroll visible. El padding lateral deja asomar la
     card siguiente — señal de que se puede deslizar. */
  @media (max-width: 767px) {
    .antes-despues__pista {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding: 0.25rem 0.25rem 1rem;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .antes-despues__pista::-webkit-scrollbar {
      display: none;
    }

    .antes-despues__card {
      flex: 0 0 85%;
      scroll-snap-align: center;
    }
  }
</style>
