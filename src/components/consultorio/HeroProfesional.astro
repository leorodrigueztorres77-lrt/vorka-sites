---
// Capa 2 (consultorio) — Hero de la Variante 1 ("El profesional es la
// estrella", referencia visual: Dentava). Foto grande del profesional +
// nombre, especialidad y credenciales visibles sin scroll — la persona es la
// marca, a diferencia de V3 (el equipamiento) o V4 (la prueba social).
// CLAUDE.md prohíbe una foto de "doctor genérico" de stock aquí: `perfil.foto`
// debe ser real (o mejorada con IA) antes de cualquier entrega a un cliente.
import type { PerfilProfesional, SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
  perfil: PerfilProfesional;
}

const { site, perfil } = Astro.props;
---

<section id="inicio" class="hero-profesional">
  <div class="container hero-profesional__grid">
    <div class="hero-profesional__texto">
      {perfil.aniosExperiencia && (
        <p class="hero-profesional__badge reveal">{perfil.aniosExperiencia} años de experiencia en {site.ciudad}</p>
      )}
      <h1 class="hero-profesional__nombre reveal">{perfil.nombre}</h1>
      <p class="hero-profesional__titulo reveal">
        {perfil.tituloProfesional}{perfil.especialidad ? ` · ${perfil.especialidad}` : ''}
      </p>

      {perfil.credenciales && perfil.credenciales.length > 0 && (
        <ul class="hero-profesional__credenciales reveal">
          {perfil.credenciales.map((c) => <li>{c}</li>)}
        </ul>
      )}

      <div class="hero-profesional__cta reveal">
        <slot name="cta" />
      </div>
    </div>

    <div class="hero-profesional__foto reveal--scale">
      <img
        src={perfil.foto ?? '/images/placeholder-profesional.webp'}
        alt={perfil.nombre}
        loading="eager"
        width="560"
        height="640"
      />
    </div>
  </div>
</section>

<style>
  .hero-profesional {
    background: var(--color-fondo-alterno);
    padding: 8rem 0 4rem;
  }

  .hero-profesional__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 800px) {
    .hero-profesional__grid {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }

  .hero-profesional__badge {
    display: inline-block;
    background: var(--color-acento);
    color: var(--color-texto);
    border-radius: 100px;
    padding: 0.35rem 1.1rem;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .hero-profesional__nombre {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.1;
    margin: 0 0 0.5rem;
    color: var(--color-primario);
  }

  .hero-profesional__titulo {
    font-size: 1.2rem;
    opacity: 0.85;
    margin: 0 0 1.5rem;
  }

  .hero-profesional__credenciales {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }

  .hero-profesional__credenciales li {
    padding-left: 1.4rem;
    position: relative;
    font-size: 1rem;
    opacity: 0.85;
  }

  .hero-profesional__credenciales li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primario);
    font-weight: 700;
  }

  .hero-profesional__foto img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 20px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
  }
</style>
