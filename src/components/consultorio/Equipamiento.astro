---
// Capa 2 (consultorio) — sección de equipamiento de la Variante 3 ("La
// modernidad y el equipamiento").
//
// REFACTOR 2026-07-21 (Fase 2, spec de diseño de Leo): pasa de galería de
// fotos a argumento — cada ítem es una tarjeta con título del equipo +
// beneficio redactado en lenguaje de paciente (no ficha técnica), y debajo un
// banner destacado con el diferenciador principal ("Rayos X digital gratis en
// cada consulta") + CTA de WhatsApp. El banner es opcional: sin
// `bannerTexto`/`phone`/`negocioSlug`, la sección se queda solo con las
// tarjetas (comportamiento seguro para cualquier caller que no los pase).
import type { FotoGaleria, ItemTecnologia } from '@/data/types';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';

interface Props {
  items: ItemTecnologia[];
  /**
   * Fotos de cabecera de las tarjetas (16:9, lazy), emparejadas por índice
   * con `items` — clínica/equipos reales del negocio. Opcional: sin esto las
   * tarjetas quedan solo con texto (comportamiento anterior a 2026-07-22).
   */
  fotos?: FotoGaleria[];
  /** Diferenciador principal, ej. "Rayos X digital gratis en cada consulta". */
  bannerTexto?: string;
  phone?: string;
  negocioSlug?: string;
  /** Mensaje pre-llenado del WhatsApp del banner — distinto al de otros CTAs para medir origen. */
  bannerMensaje?: string;
}

const { items, fotos, bannerTexto, phone, negocioSlug, bannerMensaje } = Astro.props;
const mostrarBanner = Boolean(bannerTexto && phone && negocioSlug);
---

<section id="tecnologia" class="section section--alterno" aria-labelledby="tecnologia-titulo">
  <div class="container">
    <h2 id="tecnologia-titulo" class="section-title">Nuestra tecnología</h2>
    <p class="equipamiento__intro">Equipos e instalaciones pensados para que tu visita sea rápida, cómoda y precisa.</p>

    <div class="equipamiento__grid">
      {items.map((item, i) => (
        <div class="equipamiento__card reveal">
          {fotos?.[i] && (
            <img
              class="equipamiento__card-foto"
              src={fotos[i].src}
              srcset={fotos[i].src2x ? `${fotos[i].src} 1x, ${fotos[i].src2x} 2x` : undefined}
              alt={fotos[i].alt}
              loading="lazy"
              width="800"
              height="450"
            />
          )}
          <div class="equipamiento__card-cuerpo">
            <h3 class="equipamiento__card-titulo">{item.titulo}</h3>
            <p class="equipamiento__card-beneficio">{item.beneficio}</p>
          </div>
        </div>
      ))}
    </div>

    {mostrarBanner && (
      <div class="equipamiento__banner reveal">
        <p class="equipamiento__banner-texto">{bannerTexto}</p>
        <WhatsAppButton
          phone={phone!}
          message={bannerMensaje ?? bannerTexto!}
          negocioSlug={negocioSlug!}
          label="Agendar por WhatsApp"
          variante="acento"
        />
      </div>
    )}
  </div>
</section>

<style>
  .equipamiento__intro {
    max-width: 560px;
    margin: 0 0 2rem;
    opacity: 0.8;
  }

  .equipamiento__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 700px) {
    .equipamiento__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .equipamiento__card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .equipamiento__card-foto {
    width: 100%;
    height: auto; /* sin esto, el atributo height del <img> pisa al aspect-ratio */
    aspect-ratio: 16 / 9;
    object-fit: cover;
    /* Regla de profundidad visual #1 (CLAUDE.md): mismo filtro que el resto
       de fotos del sitio para que las tres cabeceras se lean como un solo
       lugar. */
    filter: saturate(1.05) brightness(1.02) contrast(1.03);
  }

  .equipamiento__card-cuerpo {
    padding: 1.5rem 2rem 2rem;
  }

  .equipamiento__card-titulo {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-primario);
    margin: 0 0 0.5rem;
  }

  .equipamiento__card-beneficio {
    font-family: var(--font-texto);
    line-height: 1.6;
    opacity: 0.85;
    margin: 0;
  }

  .equipamiento__banner {
    margin-top: 2.5rem;
    background: var(--color-primario);
    color: #fff;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .equipamiento__banner-texto {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin: 0;
    max-width: 480px;
  }
</style>
