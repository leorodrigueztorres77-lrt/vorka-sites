---
// Capa 2 (consultorio) — sección de equipamiento de la Variante 3 ("La
// modernidad y el equipamiento"). Análoga a GaleriaMasonry (restaurante):
// integrada como sección con título y contexto propio ("Nuestra
// tecnología"), nunca una galería flotante desconectada (CLAUDE.md).
import type { FotoGaleria } from '@/data/types';

interface Props {
  fotos: FotoGaleria[];
}

const { fotos } = Astro.props;
---

<section id="tecnologia" class="section section--alterno" aria-labelledby="tecnologia-titulo">
  <div class="container">
    <h2 id="tecnologia-titulo" class="section-title">Nuestra tecnología</h2>
    <p class="equipamiento__intro">Equipos e instalaciones pensados para que tu visita sea rápida, cómoda y precisa.</p>

    <div class="equipamiento__grid">
      {fotos.map((foto, i) => (
        <img
          src={foto.src}
          alt={foto.alt}
          loading="lazy"
          class:list={['equipamiento__foto', { 'equipamiento__foto--alta': i % 3 === 0 }, 'reveal--iris']}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .equipamiento__intro {
    max-width: 560px;
    margin: 0 0 2rem;
    opacity: 0.8;
  }

  .equipamiento__grid {
    columns: 2;
    column-gap: 1rem;
  }

  @media (min-width: 700px) {
    .equipamiento__grid {
      columns: 3;
    }
  }

  .equipamiento__foto {
    width: 100%;
    display: block;
    margin-bottom: 1rem;
    border-radius: 14px;
    break-inside: avoid;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    /* Regla de profundidad visual #1 (CLAUDE.md): mismo filtro de color en
       todas las fotos del sitio. Tono más frío/clínico que el de
       restaurante (sin el sepia cálido), acorde a la paleta teal/azul del
       vertical consultorio. */
    filter: saturate(1.05) brightness(1.02) contrast(1.03);
    height: 160px;
    object-fit: cover;
  }

  .equipamiento__foto--alta {
    height: 230px;
  }
</style>
