---
// Capa 2 (restaurante) — menú de la Variante 5 ("Variedad, comunidad y pedido
// directo"). Filtro por categoría con animación suave de fade + "Ver más" en
// vez de mostrar toda la carta de golpe (para catálogos de 10+ platos). Cada
// tarjeta lleva foto cuadrada + badge de tipo (si el plato lo tiene).
import type { CategoriaMenu } from '@/data/types';
import MenuItemQuantity from './MenuItemQuantity.astro';

interface Props {
  categorias: CategoriaMenu[];
  phone: string;
  negocioSlug: string;
  /** Cuántas tarjetas mostrar antes de "Ver más". */
  porPagina?: number;
}

const { categorias, phone, negocioSlug, porPagina = 9 } = Astro.props;
const slug = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-');

const todosPlatos = categorias.flatMap((cat) =>
  cat.platos.map((p) => ({ ...p, categoria: cat.categoria })),
);
---

<section id="menu" class="section" aria-labelledby="menu-titulo">
  <div class="container">
    <h2 id="menu-titulo" class="section-title">Nuestro Menú</h2>

    <div class="menu-filtrable" data-menu-filtrable data-por-pagina={porPagina}>
      <div class="menu-filtrable__filtros" role="tablist">
        <button type="button" class="menu-filtrable__filtro is-activo" data-filtro="todos">Todos</button>
        {categorias.map((cat) => (
          <button type="button" class="menu-filtrable__filtro" data-filtro={slug(cat.categoria)}>
            {cat.categoria}
          </button>
        ))}
      </div>

      <div class="menu-filtrable__grid">
        {todosPlatos.map((plato) => (
          <article class="menu-filtrable__card reveal--scale" data-plato data-categoria={slug(plato.categoria)}>
            {plato.imagen && <img src={plato.imagen} alt={plato.nombre} loading="lazy" width="280" height="200" />}
            <div class="menu-filtrable__cuerpo">
              {plato.tipo && <span class="menu-filtrable__badge">{plato.tipo}</span>}
              <p class="menu-filtrable__nombre">{plato.nombre}</p>
              {plato.descripcion && <p class="menu-filtrable__descripcion">{plato.descripcion}</p>}
              <div class="menu-filtrable__fila">
                <span class="menu-filtrable__precio">${plato.precio.toFixed(2)}</span>
                <MenuItemQuantity
                  phone={phone}
                  negocioSlug={negocioSlug}
                  nombrePlato={plato.nombre}
                  precio={plato.precio}
                />
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="menu-filtrable__mas">
        <button type="button" class="menu-filtrable__boton-mas" data-ver-mas>Ver más</button>
      </div>
    </div>
  </div>
</section>

<script>
  import { revelarEscalonado, ocultarReveal } from '@/lib/motion';

  document.querySelectorAll<HTMLElement>('[data-menu-filtrable]').forEach((contenedor) => {
    const porPagina = parseInt(contenedor.dataset.porPagina ?? '9', 10);
    const filtros = contenedor.querySelectorAll<HTMLButtonElement>('[data-filtro]');
    const tarjetas = Array.from(contenedor.querySelectorAll<HTMLElement>('[data-plato]'));
    const botonMas = contenedor.querySelector<HTMLButtonElement>('[data-ver-mas]');

    let filtroActivo = 'todos';
    let visibles = porPagina;

    const aplicar = () => {
      const coinciden = tarjetas.filter((t) => filtroActivo === 'todos' || t.dataset.categoria === filtroActivo);
      ocultarReveal(tarjetas);
      tarjetas.forEach((t) => { t.style.display = 'none'; });
      const mostradas = coinciden.slice(0, visibles);
      mostradas.forEach((t) => { t.style.display = ''; });
      revelarEscalonado(mostradas, 60);
      if (botonMas) botonMas.style.display = coinciden.length > visibles ? '' : 'none';
    };

    filtros.forEach((boton) => {
      boton.addEventListener('click', () => {
        filtroActivo = boton.dataset.filtro ?? 'todos';
        visibles = porPagina;
        filtros.forEach((b) => b.classList.toggle('is-activo', b === boton));
        aplicar();
      });
    });

    botonMas?.addEventListener('click', () => {
      visibles += porPagina;
      aplicar();
    });

    aplicar();
  });
</script>

<style>
  .menu-filtrable__filtros {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .menu-filtrable__filtro {
    min-height: 44px;
    padding: 0.6rem 1.4rem;
    border-radius: 100px;
    border: 1px solid var(--color-fondo-alterno);
    background: var(--color-fondo, #fff);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: background 200ms ease, color 200ms ease;
  }

  .menu-filtrable__filtro.is-activo {
    background: var(--color-primario);
    color: #fff;
    border-color: var(--color-primario);
  }

  .menu-filtrable__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .menu-filtrable__card {
    border-radius: 14px;
    overflow: hidden;
    background: var(--color-fondo, #fff);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .menu-filtrable__card img {
    width: 100%;
    height: 160px;
    object-fit: cover;
  }

  .menu-filtrable__cuerpo {
    padding: 1rem;
    position: relative;
  }

  .menu-filtrable__badge {
    display: inline-block;
    background: var(--color-acento);
    color: var(--color-texto);
    font-size: 1rem;
    font-weight: 600;
    padding: 0.2rem 0.7rem;
    border-radius: 100px;
    margin-bottom: 0.5rem;
  }

  .menu-filtrable__nombre {
    font-weight: 700;
    margin: 0 0 0.3rem;
  }

  .menu-filtrable__descripcion {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    opacity: 0.75;
  }

  .menu-filtrable__fila {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .menu-filtrable__precio {
    font-weight: 700;
    color: var(--color-primario);
  }

  .menu-filtrable__mas {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  .menu-filtrable__boton-mas {
    min-height: 44px;
    padding: 0.75rem 2rem;
    border-radius: 100px;
    border: 2px solid var(--color-primario);
    background: transparent;
    color: var(--color-primario);
    font-weight: 600;
    cursor: pointer;
  }
</style>
