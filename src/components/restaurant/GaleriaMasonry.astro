---
// Capa 2 (restaurante) — galería de la Variante 5 ("Variedad, comunidad y
// pedido directo"). A diferencia de una galería flotante desconectada
// (prohibida por CLAUDE.md), esta va integrada como sección con título y
// contexto propio ("Nuestra cocina"), en formato masonry de 6-9 fotos.
import type { FotoGaleria } from '@/data/types';

interface Props {
  fotos: FotoGaleria[];
}

const { fotos } = Astro.props;
---

<section id="cocina" class="section section--alterno" aria-labelledby="cocina-titulo">
  <div class="container">
    <h2 id="cocina-titulo" class="section-title">Nuestra cocina</h2>
    <p class="galeria-masonry__intro">Un vistazo a lo que preparamos cada día, con los mismos ingredientes de siempre.</p>

    <div class="galeria-masonry">
      {fotos.map((foto, i) => (
        <img
          src={foto.src}
          alt={foto.alt}
          loading="lazy"
          class:list={['galeria-masonry__foto', { 'galeria-masonry__foto--alta': i % 3 === 0 }, 'reveal--iris']}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .galeria-masonry__intro {
    max-width: 560px;
    margin: 0 0 2rem;
    opacity: 0.8;
  }

  .galeria-masonry {
    columns: 2;
    column-gap: 1rem;
  }

  @media (min-width: 700px) {
    .galeria-masonry {
      columns: 3;
    }
  }

  .galeria-masonry__foto {
    width: 100%;
    display: block;
    margin-bottom: 1rem;
    border-radius: 14px;
    break-inside: avoid;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    /* Regla de profundidad visual #1 (CLAUDE.md): mismo filtro de color en
       todas las fotos del sitio, sin importar la fuente de cada una. */
    filter: saturate(1.15) brightness(0.95) contrast(1.03) sepia(0.06);
    height: 160px;
    object-fit: cover;
  }

  .galeria-masonry__foto--alta {
    height: 230px;
  }
</style>
