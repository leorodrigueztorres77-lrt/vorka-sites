---
// Capa 2 (restaurante) — Hero de la Variante 5 ("Variedad, comunidad y
// pedido directo", referencia visual: Craving). Collage de 3 fotos de platos
// energético + titular directo + fila de contadores animados (StatsFila) +
// doble CTA (Ver menú / Pedir por WhatsApp) en la misma fila.
import type { SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
  fotosCollage: [string, string, string];
  titular: string;
}

const { site, fotosCollage, titular } = Astro.props;
---

<section id="inicio" class="hero-collage">
  <div class="container hero-collage__inner">
    <div class="hero-collage__texto">
      <h1 class="hero-collage__titular reveal">{titular}</h1>
      <p class="hero-collage__subtitulo reveal">{site.tagline}</p>
      <div class="hero-collage__cta reveal">
        <a href="#menu" class="hero-collage__boton-secundario">Ver el menú</a>
        <slot name="cta" />
      </div>
    </div>

    <div class="hero-collage__fotos reveal--scale">
      <img src={fotosCollage[0]} alt="" loading="eager" class="hero-collage__foto hero-collage__foto--grande" />
      <img src={fotosCollage[1]} alt="" loading="lazy" class="hero-collage__foto" />
      <img src={fotosCollage[2]} alt="" loading="lazy" class="hero-collage__foto" />
    </div>
  </div>

  <div class="hero-collage__stats-slot">
    <slot name="stats" />
  </div>
</section>

<style>
  .hero-collage {
    padding: 7rem 0 0;
    background: var(--color-fondo, #fff);
  }

  .hero-collage__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    padding-bottom: 3rem;
  }

  @media (min-width: 800px) {
    .hero-collage__inner {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hero-collage__titular {
    font-family: var(--font-titulos);
    font-weight: 700;
    font-size: clamp(2.25rem, 5.5vw, 4.5rem);
    line-height: 1.08;
    margin: 0 0 1.25rem;
    color: var(--color-primario);
  }

  .hero-collage__subtitulo {
    font-size: 1.15rem;
    opacity: 0.85;
    max-width: 460px;
    margin: 0 0 2rem;
  }

  .hero-collage__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-collage__boton-secundario {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.85rem 1.75rem;
    border: 2px solid var(--color-primario);
    color: var(--color-primario);
    border-radius: 100px;
    font-weight: 600;
    text-decoration: none;
  }

  .hero-collage__fotos {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 140px);
    gap: 0.75rem;
  }

  .hero-collage__foto {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .hero-collage__foto--grande {
    grid-row: 1 / 3;
  }
</style>
