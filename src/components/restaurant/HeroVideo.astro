---
// Capa 2 (restaurante) — Hero de la Variante 3 ("La atmósfera y la
// experiencia", referencia visual: Qitchen). Video de fondo en loop si existe;
// si no, foto del ambiente con Ken Burns suave (zoom lento) como respaldo —
// la mayoría de clientes no tendrán video propio en la primera entrega.
// Deliberadamente sin subtítulo, sin badges, sin señal social: la atmósfera
// habla sola (regla de la variante en la skill vertical-web-builder).
interface Props {
  /** Si se pasa, tiene prioridad sobre imagenFondo. */
  videoFondo?: string;
  imagenFondo: string;
  /** Titular corto, máx. 4 palabras. */
  titular: string;
}

const { videoFondo, imagenFondo, titular } = Astro.props;
---

<section id="inicio" class="hero-video">
  {videoFondo ? (
    <video class="hero-video__media" autoplay muted loop playsinline poster={imagenFondo}>
      <source src={videoFondo} type="video/mp4" />
    </video>
  ) : (
    <div class="hero-video__media hero-video__media--foto" style={`background-image: url(${imagenFondo})`} />
  )}

  <div class="hero-video__overlay"></div>

  <div class="container hero-video__inner">
    <h1 class="hero-video__titular reveal">{titular}</h1>
    <div class="hero-video__cta reveal">
      <slot name="cta" />
    </div>
  </div>
</section>

<style>
  .hero-video {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #fff;
    text-align: center;
  }

  .hero-video__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video__media--foto {
    background-size: cover;
    background-position: center;
    animation: kenburns 20s ease-in-out infinite alternate;
  }

  @keyframes kenburns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.12);
    }
  }

  .hero-video__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .hero-video__inner {
    position: relative;
    z-index: 1;
  }

  .hero-video__titular {
    font-family: var(--font-titulos);
    font-style: italic;
    font-weight: 700;
    color: #fff;
    font-size: clamp(2.5rem, 9vw, 7.5rem);
    line-height: 1.05;
    margin: 0 0 2rem;
  }

  .hero-video__cta {
    display: flex;
    justify-content: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video__media--foto {
      animation: none;
    }
  }
</style>
