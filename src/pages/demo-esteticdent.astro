---
// Capa 3 — Estetic Dent (consultorio odontológico, Quito).
// Variante Capa 2: V3 "Vervedent" — ver razonamiento en src/data/site.esteticdent.ts.
//
// REVERTIDO 2026-07-19 (feedback directo de Leo): la excepción puntual del
// 2026-07-19 que mostraba la foto real de la Od. Mishel Chamorro en el hero
// (vía HeroSplit) se deshace — Leo pidió quitar su foto del hero por completo
// ("no hay armonía, no se ve como un sitio top profesional"). Vuelve el hero
// default de V3: HeroEquipamiento con foto de fondo a pantalla completa (sin
// personas), coherente además con que Estetic Dent es un equipo de varios
// especialistas, no una marca de un solo profesional-estrella (ver
// site.esteticdent.ts). La foto de Mishel (mishel-chamorro-hero-ia.webp)
// queda en disco sin usarse en ninguna página — ver README.md de
// public/images/esteticdent/ para su estado.
//
// Mismo feedback también señaló falta de armonía en el orden de secciones:
// Testimonials se sube de posición (ahora justo después del Hero, antes de
// Servicios) en vez de quedar hasta el final de la página. CLAUDE.md
// documenta que Carbon Health/One Medical usan la secuencia "propuesta →
// prueba social → servicios", y Odontocrea (V2, misma vertical) ya sigue ese
// patrón con su sección Historia justo después del hero — V3 no tenía ningún
// beat de confianza temprano, solo dos secciones de equipamiento seguidas
// (Servicios con foto destacada + Equipamiento) antes de llegar a los
// testimonios. Este reorden no es un cambio de Capa 2 (Testimonials ya es
// Capa 1, position-agnostic) — es composición de página, propia de Capa 3.
//
// AJUSTE 2026-07-21: TeamSection también se sube — pasa de estar al final de
// la página (después de Equipamiento) a justo después de Testimonials. Con la
// foto real de la Dra. Chamorro ya incorporada (ver consultorio.esteticdent.ts),
// esto pone una cara humana antes del segundo scroll, sin la cual la variante
// V3 (equipamiento/tecnología) se leía como un consultorio vacío — feedback
// directo de Leo tras ver el hero corregido: "no tiene calidez... sin
// personas sin doctores". Mismo principio que el reorden de Testimonials de
// arriba: composición de página (Capa 3), TeamSection sigue siendo Capa 1/2
// position-agnostic.
//
// REFACTOR 2026-07-21 (Fase 1, spec de diseño de Leo): nuevo orden de
// secciones — Hero → Servicios → Tecnología → Equipo → Testimonios →
// Ubicación → Contacto. Reemplaza el orden anterior (Hero → Testimonios →
// Equipo → Servicios → Tecnología); la lógica de "propuesta → prueba social"
// se mantiene pero ahora Servicios/Tecnología (el argumento de la variante
// V3) va primero, y el bloque de confianza humana (Equipo + Testimonios) va
// justo antes del cierre (Ubicación/Contacto).
//
// Hero: `eyebrow`/`subheadline` usan copy confirmado (zona Quitumbe, rayos X
// gratis — ya documentados arriba en site.esteticdent.ts). `pruebaSocial` NO
// se pasa: el spec pedía literal "★ 4.9 en Google", pero
// site.esteticdent.ts confirma que ratingGoogle/googleBusinessUrl no están
// confirmados todavía — mostrar esa cifra sería inventar una calificación
// (CLAUDE.md, regla explícita). El componente ya soporta la línea si Leo
// confirma el dato real más adelante.
//
// FASE 2 (spec de diseño de Leo): #tecnologia pasa de galería de fotos a
// argumento — Equipamiento ahora recibe `items` (título+beneficio, ver
// tecnologiaEsteticdent en consultorio.esteticdent.ts) en vez de `fotos`, más
// un banner con el diferenciador principal (rayos X gratis) y su propio CTA
// de WhatsApp con mensaje distinto para medir origen.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import Testimonials from '@/components/common/Testimonials.astro';
import LocationMap from '@/components/common/LocationMap.astro';
import ContactForm from '@/components/common/ContactForm.astro';
import Footer from '@/components/common/Footer.astro';
import FloatingWhatsApp from '@/components/common/FloatingWhatsApp.astro';

import HeroEquipamiento from '@/components/consultorio/HeroEquipamiento.astro';
import ServiciosTipografico from '@/components/consultorio/ServiciosTipografico.astro';
import Equipamiento from '@/components/consultorio/Equipamiento.astro';
import TeamSection from '@/components/consultorio/TeamSection.astro';

import { siteConfigEsteticdent } from '@/data/site.esteticdent';
import {
  serviciosEsteticdent,
  galeriaEsteticdent,
  tecnologiaEsteticdent,
  horariosEsteticdent,
  testimoniosEsteticdent,
  profesionalesEsteticdent,
} from '@/data/consultorio.esteticdent';
import { validarConfigCliente } from '@/lib/validarConfigCliente';
import { schemaConsultorio } from '@/lib/schemaOrg';

const site = siteConfigEsteticdent;
const equipoDestacado = galeriaEsteticdent[1];
// La foto destacada de arriba ya se muestra en grande en ServiciosTipografico —
// se excluye aquí para que Equipamiento no la repita en la grilla masonry.
const fotosEquipamiento = galeriaEsteticdent.filter((_, i) => i !== 1);

// Demo de venta a prospecto (todavía no cliente confirmado) — muestra el
// bloque ilustrativo de Testimonials en vez de ocultar la sección entera.
const modoDemo = true;

validarConfigCliente({
  site,
  servicios: serviciosEsteticdent,
  galeria: galeriaEsteticdent,
  horarios: horariosEsteticdent,
});

// SEO local (spec SALUD 2026-07-20). Título afinado con la zona ya
// confirmada (Quitumbe, ver site.esteticdent.ts) — más específico que solo
// "Quito" para búsquedas locales, sin inventar ningún dato nuevo.
const tituloPagina = 'Estetic Dent — Odontología estética en Quitumbe, Quito';
const schema = schemaConsultorio({
  site,
  url: 'https://vorka-sites.vercel.app/demo-esteticdent/',
  tipo: 'Dentist',
  horarios: horariosEsteticdent,
  servicios: serviciosEsteticdent,
});
---

<BaseLayout site={site} titulo={tituloPagina} ogImage={new URL(galeriaEsteticdent[0].src, 'https://vorka-sites.vercel.app').href}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Header
    site={site}
    navItems={[
      { label: 'Servicios', href: '#servicios' },
      { label: 'Nuestra tecnología', href: '#tecnologia' },
      { label: 'Contacto', href: '#contacto' },
    ]}
  />

  <HeroEquipamiento
    imagenFondo={galeriaEsteticdent[0].src}
    eyebrow="Odontología de especialidades · Quitumbe, Quito"
    titular="Precisión dental, sin esperas"
    subheadline="Especialistas en ortodoncia, endodoncia y cirugía oral. Rayos X digital gratis en cada consulta."
  >
    <Fragment slot="cta">
      <WhatsAppButton
        phone={site.telefonoWhatsApp}
        message={`Hola, quiero agendar una cita en ${site.nombre}`}
        negocioSlug={site.negocioSlug}
        label="Agendar cita por WhatsApp"
        variante="acento"
      />
    </Fragment>
  </HeroEquipamiento>

  <ServiciosTipografico
    categorias={serviciosEsteticdent}
    fotoEquipoDestacado={equipoDestacado.src}
    nombreEquipoDestacado={equipoDestacado.alt}
    phone={site.telefonoWhatsApp}
    negocioSlug={site.negocioSlug}
  />

  <Equipamiento
    items={tecnologiaEsteticdent}
    bannerTexto="Rayos X digital gratis en cada consulta"
    bannerMensaje={`Hola, quiero agendar mi consulta con rayos X digital gratis en ${site.nombre}`}
    phone={site.telefonoWhatsApp}
    negocioSlug={site.negocioSlug}
  />

  <TeamSection profesionales={profesionalesEsteticdent} />

  <Testimonials
    testimonios={testimoniosEsteticdent}
    fondoSolido
    patron
    modoDemo={modoDemo}
    fotos={fotosEquipamiento}
  />

  <LocationMap site={site} horarios={horariosEsteticdent} />

  <ContactForm site={site} productoLabel="Servicio de interés" mostrarCantidad={false} />

  <Footer site={site} />

  <FloatingWhatsApp
    phone={site.telefonoWhatsApp}
    message={`Hola, quiero agendar una cita en ${site.nombre}`}
    negocioSlug={site.negocioSlug}
  />
</BaseLayout>
