---
// Capa 3 — Shangrila (restaurante, Valle de los Chillos, Quito).
// Variante Capa 2 elegida por Leo: V2 "Restroo" — menú completo con tabs,
// distinta de la variante usada en El Fogón Ecuatoriano (V1). Usa el hero
// superpuesto y el menú con portada dramática ya adoptados en Capa 1/2 (con
// autorización de Leo) — esta página solo aporta los datos de Capa 3.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import HeroSplit from '@/components/common/HeroSplit.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import Testimonials from '@/components/common/Testimonials.astro';
import LocationMap from '@/components/common/LocationMap.astro';
import ContactForm from '@/components/common/ContactForm.astro';
import Footer from '@/components/common/Footer.astro';
import FloatingWhatsApp from '@/components/common/FloatingWhatsApp.astro';

import Historia from '@/components/restaurant/Historia.astro';
import MenuTabs from '@/components/restaurant/MenuTabs.astro';
import CartBar from '@/components/restaurant/CartBar.astro';

import { siteConfigShangrila } from '@/data/site.shangrila';
import {
  menuShangrila,
  horariosShangrila,
  testimoniosShangrila,
  historiaShangrila,
  heroFotoShangrila,
} from '@/data/restaurant.shangrila';

const site = siteConfigShangrila;
---

<BaseLayout site={site}>
  <Header site={site} />

  <HeroSplit site={site} imagen={heroFotoShangrila} imagenAlt="Parrillada de Shangrila recién servida" estilo="superpuesto">
    <Fragment slot="cta">
      <a class="btn btn--primario" href="#menu">Ver el menú completo</a>
      <WhatsAppButton
        phone={site.telefonoWhatsApp}
        message={`Hola, quiero hacer un pedido en ${site.nombre}`}
        negocioSlug={site.negocioSlug}
        label="Pedir por WhatsApp"
        variante="acento"
      />
    </Fragment>
  </HeroSplit>

  <Historia historia={historiaShangrila} nombreNegocio={site.nombre} fondoAlterno revealFoto="escala" />

  <MenuTabs categorias={menuShangrila} phone={site.telefonoWhatsApp} negocioSlug={site.negocioSlug} />

  <Testimonials testimonios={testimoniosShangrila} carrusel fondoSolido />

  <LocationMap site={site} horarios={horariosShangrila} />

  <ContactForm site={site} productoLabel="Plato de interés" />

  <Footer site={site} />

  <CartBar phone={site.telefonoWhatsApp} negocioSlug={site.negocioSlug} nombreNegocio={site.nombre} />

  <FloatingWhatsApp
    phone={site.telefonoWhatsApp}
    message={`Hola, quiero hacer un pedido en ${site.nombre}`}
    negocioSlug={site.negocioSlug}
    bottomOffset="88px"
  />
</BaseLayout>
