---
// Restaurante — Variante 1 "Umami" (Capa 2).
// Argumento de conversión: "El producto es la estrella" — para restaurantes
// con un plato icónico reconocible. Hero de foto a pantalla completa con
// titular partido en 3 líneas y fotos de plato intercaladas, menú con
// tarjetas destacadas, galería en banda de scroll automático.
// demo-personalizer copia esta estructura como punto de partida cuando esta
// es la variante asignada al cliente — el contenido real reemplaza las
// muestras importadas de restaurant.sample.ts.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import Testimonials from '@/components/common/Testimonials.astro';
import LocationMap from '@/components/common/LocationMap.astro';
import ContactForm from '@/components/common/ContactForm.astro';
import Footer from '@/components/common/Footer.astro';
import FloatingWhatsApp from '@/components/common/FloatingWhatsApp.astro';

import HeroUmami from '@/components/restaurant/HeroUmami.astro';
import MenuDestacado from '@/components/restaurant/MenuDestacado.astro';
import GaleriaMarquee from '@/components/restaurant/GaleriaMarquee.astro';
import LoyaltyStatus from '@/components/restaurant/LoyaltyStatus.astro';
import CartBar from '@/components/restaurant/CartBar.astro';

import { siteConfig } from '@/data/site.config';
import {
  menuSample,
  galeriaSample,
  horariosSample,
  testimoniosSample,
  estadoFidelizacionSample,
  statsSample,
} from '@/data/restaurant.sample';

const mostrarFidelizacion = Boolean(estadoFidelizacionSample);

// Placeholder — demo-personalizer reemplaza este titular partido en 3 líneas
// con el nombre del plato icónico real del cliente (ver skill vertical-web-builder, V1).
const titularHero: [string, string, string] = ['EL SABOR', 'QUE', 'RECUERDAS'];
---

<BaseLayout site={siteConfig}>
  <Header site={siteConfig} />

  <HeroUmami
    site={siteConfig}
    imagenFondo="/images/placeholder-hero.webp"
    titular={titularHero}
    fotoPlato1={galeriaSample[0].src}
    fotoPlato2={galeriaSample[1].src}
    stats={statsSample}
  >
    <Fragment slot="cta">
      <WhatsAppButton
        phone={siteConfig.telefonoWhatsApp}
        message={`Hola, quiero hacer un pedido en ${siteConfig.nombre}`}
        negocioSlug={siteConfig.negocioSlug}
        label="Pedir por WhatsApp"
        variante="acento"
      />
    </Fragment>
  </HeroUmami>

  <MenuDestacado
    categorias={menuSample}
    phone={siteConfig.telefonoWhatsApp}
    negocioSlug={siteConfig.negocioSlug}
  />

  <GaleriaMarquee fotos={galeriaSample} />

  {mostrarFidelizacion && (
    <section class="section" aria-labelledby="fidelizacion-titulo">
      <div class="container fidelizacion-grid">
        <h2 id="fidelizacion-titulo" class="section-title">Tu progreso como cliente frecuente</h2>
        <LoyaltyStatus estado={estadoFidelizacionSample} />
      </div>
    </section>
  )}

  <Testimonials testimonios={testimoniosSample} carrusel fondoSolido />

  <LocationMap site={siteConfig} horarios={horariosSample} />

  <ContactForm site={siteConfig} productoLabel="Plato de interés" />

  <Footer site={siteConfig} />

  <CartBar
    phone={siteConfig.telefonoWhatsApp}
    negocioSlug={siteConfig.negocioSlug}
    nombreNegocio={siteConfig.nombre}
  />

  <FloatingWhatsApp
    phone={siteConfig.telefonoWhatsApp}
    message={`Hola, quiero hacer un pedido en ${siteConfig.nombre}`}
    negocioSlug={siteConfig.negocioSlug}
    bottomOffset="88px"
  />
</BaseLayout>

<style>
  .fidelizacion-grid {
    max-width: 480px;
    margin: 0 auto;
  }
</style>
