---
// Restaurante — Variante 5 "Craving" (Capa 2).
// Argumento de conversión: "Variedad, comunidad y pedido directo" — para
// restaurantes con carta amplia y presencia en redes, donde el volumen y la
// variedad son el argumento. Contadores animados en el hero, menú filtrable
// por tipo, galería masonry integrada, beneficios numerados, CTA final enérgico.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import Testimonials from '@/components/common/Testimonials.astro';
import LocationMap from '@/components/common/LocationMap.astro';
import ContactForm from '@/components/common/ContactForm.astro';
import Footer from '@/components/common/Footer.astro';
import FloatingWhatsApp from '@/components/common/FloatingWhatsApp.astro';

import HeroCollage from '@/components/restaurant/HeroCollage.astro';
import StatsFila from '@/components/restaurant/StatsFila.astro';
import Historia from '@/components/restaurant/Historia.astro';
import MenuFiltrable from '@/components/restaurant/MenuFiltrable.astro';
import GaleriaMasonry from '@/components/restaurant/GaleriaMasonry.astro';
import BeneficiosNumerados from '@/components/restaurant/BeneficiosNumerados.astro';
import LoyaltyStatus from '@/components/restaurant/LoyaltyStatus.astro';
import CartBar from '@/components/restaurant/CartBar.astro';

import { siteConfig } from '@/data/site.config';
import {
  menuSample,
  galeriaSample,
  horariosSample,
  testimoniosSample,
  estadoFidelizacionSample,
  historiaSample,
  statsSample,
} from '@/data/restaurant.sample';

const mostrarFidelizacion = Boolean(estadoFidelizacionSample);

// Placeholder — demo-personalizer reemplaza estos 3 beneficios con los
// diferenciadores reales del cliente (ver skill vertical-web-builder, V5).
const beneficiosSample = [
  { titulo: 'Ingredientes frescos cada día', descripcion: 'Compramos en el mercado local cada mañana.' },
  { titulo: 'Pedido directo por WhatsApp', descripcion: 'Sin apps ni comisiones — hablas directo con nosotros.' },
  { titulo: 'Listo en 20 minutos', descripcion: 'Tu pedido preparado al momento, fresco y a tiempo.' },
];
---

<BaseLayout site={siteConfig}>
  <Header site={siteConfig} transparente={false} />

  <HeroCollage
    site={siteConfig}
    fotosCollage={[galeriaSample[0].src, galeriaSample[1].src, galeriaSample[2].src]}
    titular={`Con hambre de algo bueno, ${siteConfig.ciudad.split(',')[0]}`}
  >
    <Fragment slot="cta">
      <WhatsAppButton
        phone={siteConfig.telefonoWhatsApp}
        message={`Hola, quiero hacer un pedido en ${siteConfig.nombre}`}
        negocioSlug={siteConfig.negocioSlug}
        label="Pedir por WhatsApp"
        variante="primario"
      />
    </Fragment>
    <Fragment slot="stats">
      <StatsFila stats={statsSample} />
    </Fragment>
  </HeroCollage>

  <Historia historia={historiaSample} nombreNegocio={siteConfig.nombre} fondoAlterno fotos={galeriaSample.slice(0, 2)} revealFoto="iris" />

  <MenuFiltrable
    categorias={menuSample}
    phone={siteConfig.telefonoWhatsApp}
    negocioSlug={siteConfig.negocioSlug}
  />

  <GaleriaMasonry fotos={galeriaSample} />

  <BeneficiosNumerados beneficios={beneficiosSample} />

  {mostrarFidelizacion && (
    <section class="section" aria-labelledby="fidelizacion-titulo">
      <div class="container fidelizacion-grid">
        <h2 id="fidelizacion-titulo" class="section-title">Tu progreso como cliente frecuente</h2>
        <LoyaltyStatus estado={estadoFidelizacionSample} />
      </div>
    </section>
  )}

  <Testimonials testimonios={testimoniosSample} carrusel fondoSolido />

  <LocationMap site={siteConfig} horarios={horariosSample} />

  <section class="cta-final" aria-labelledby="cta-final-titulo">
    <div class="container cta-final__inner">
      <h2 id="cta-final-titulo" class="cta-final__titulo">¿Con hambre? Escríbenos ahora</h2>
      <WhatsAppButton
        phone={siteConfig.telefonoWhatsApp}
        message={`Hola, quiero hacer un pedido en ${siteConfig.nombre}`}
        negocioSlug={siteConfig.negocioSlug}
        label="Pedir por WhatsApp"
        variante="acento"
      />
    </div>
  </section>

  <ContactForm site={siteConfig} productoLabel="Plato de interés" />

  <Footer site={siteConfig} />

  <CartBar
    phone={siteConfig.telefonoWhatsApp}
    negocioSlug={siteConfig.negocioSlug}
    nombreNegocio={siteConfig.nombre}
  />

  <FloatingWhatsApp
    phone={siteConfig.telefonoWhatsApp}
    message={`Hola, quiero hacer un pedido en ${siteConfig.nombre}`}
    negocioSlug={siteConfig.negocioSlug}
    bottomOffset="88px"
  />
</BaseLayout>

<style>
  .fidelizacion-grid {
    max-width: 480px;
    margin: 0 auto;
  }

  .cta-final {
    padding: 4rem 0;
    background: var(--color-primario);
    color: #fff;
    text-align: center;
  }

  .cta-final__titulo {
    color: #fff;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 1.5rem;
  }
</style>
