---
// Capa 3 — Odontocrea (consultorio odontológico, Quito).
// Variante Capa 2: V2 "Reddent" — ver razonamiento en src/data/site.odontocrea.ts.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import HeroSplit from '@/components/common/HeroSplit.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import Testimonials from '@/components/common/Testimonials.astro';
import LocationMap from '@/components/common/LocationMap.astro';
import ContactForm from '@/components/common/ContactForm.astro';
import Footer from '@/components/common/Footer.astro';
import FloatingWhatsApp from '@/components/common/FloatingWhatsApp.astro';

import Historia from '@/components/restaurant/Historia.astro';
import ServiciosTabs from '@/components/consultorio/ServiciosTabs.astro';
import TeamSection from '@/components/consultorio/TeamSection.astro';

import { siteConfigOdontocrea } from '@/data/site.odontocrea';
import {
  serviciosOdontocrea,
  heroFotoOdontocrea,
  historiaOdontocrea,
  horariosOdontocrea,
  testimoniosOdontocrea,
  galeriaOdontocrea,
  profesionalesOdontocrea,
} from '@/data/consultorio.odontocrea';
import { validarConfigCliente } from '@/lib/validarConfigCliente';
import { schemaConsultorio } from '@/lib/schemaOrg';

const site = siteConfigOdontocrea;

// Demo de venta a prospecto (todavía no cliente confirmado) — muestra el
// bloque ilustrativo de Testimonials en vez de ocultar la sección entera.
const modoDemo = true;

validarConfigCliente({
  site,
  servicios: serviciosOdontocrea,
  galeria: galeriaOdontocrea,
  horarios: horariosOdontocrea,
});

// SEO local (spec SALUD 2026-07-20). Zona no se afina a un barrio único en
// el título (a diferencia de Estetic Dent) porque el negocio tiene 2 sedes en
// zonas distintas (Chillogallo + La Magdalena) — "Quito" es lo único que
// aplica a ambas sin favorecer una sobre la otra.
const schema = schemaConsultorio({
  site,
  url: 'https://vorka-sites.vercel.app/demo-odontocrea/',
  tipo: 'Dentist',
  horarios: horariosOdontocrea,
  servicios: serviciosOdontocrea,
});

const navItems = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Ubicación', href: '#ubicacion' },
  { label: 'Contacto', href: '#contacto' },
];
---

<BaseLayout site={site} ogImage={new URL(heroFotoOdontocrea, 'https://vorka-sites.vercel.app').href}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <Header site={site} navItems={navItems} />

  <HeroSplit site={site} imagen={heroFotoOdontocrea} imagenAlt="Clínica dental Odontocrea, sala de atención moderna" estilo="superpuesto">
    <Fragment slot="cta">
      <a class="btn btn--primario" href="#servicios">Ver todos los servicios</a>
      <WhatsAppButton
        phone={site.telefonoWhatsApp}
        message={`Hola, quiero agendar una cita en ${site.nombre}`}
        negocioSlug={site.negocioSlug}
        label="Agendar cita por WhatsApp"
        variante="acento"
      />
    </Fragment>
  </HeroSplit>

  <Historia historia={historiaOdontocrea} nombreNegocio={site.nombre} fondoAlterno revealFoto="escala" />

  <TeamSection profesionales={profesionalesOdontocrea} />

  <ServiciosTabs categorias={serviciosOdontocrea} phone={site.telefonoWhatsApp} negocioSlug={site.negocioSlug} />

  <Testimonials
    testimonios={testimoniosOdontocrea}
    carrusel
    fondoSolido
    patron
    modoDemo={modoDemo}
    fotos={galeriaOdontocrea.slice(1)}
  />

  <LocationMap site={site} horarios={horariosOdontocrea} />

  <ContactForm site={site} productoLabel="Especialidad de interés" mostrarCantidad={false} />

  <Footer site={site} />

  <FloatingWhatsApp
    phone={site.telefonoWhatsApp}
    message={`Hola, quiero agendar una cita en ${site.nombre}`}
    negocioSlug={site.negocioSlug}
  />
</BaseLayout>
