---
// Consultorio médico/dental — Variante 2 "Reddent" (Capa 2).
// Argumento de conversión: "Los servicios completos son el argumento" — para
// consultorios con oferta amplia donde el paciente llega a comparar qué
// necesita. Hero superpuesto (foto a pantalla completa + titular grande),
// historia del profesional antes del catálogo, servicios en tabs filtrables
// por especialidad con portada dramática (el elemento diferenciador).
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import HeroSplit from '@/components/common/HeroSplit.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import Testimonials from '@/components/common/Testimonials.astro';
import LocationMap from '@/components/common/LocationMap.astro';
import ContactForm from '@/components/common/ContactForm.astro';
import Footer from '@/components/common/Footer.astro';
import FloatingWhatsApp from '@/components/common/FloatingWhatsApp.astro';

import Historia from '@/components/restaurant/Historia.astro';
import ServiciosTabs from '@/components/consultorio/ServiciosTabs.astro';

import { siteConfigConsultorio } from '@/data/site.config.consultorio';
import { serviciosSample, galeriaSample, horariosSample, testimoniosSample, historiaSample } from '@/data/consultorio.sample';

const navItems = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Ubicación', href: '#ubicacion' },
  { label: 'Contacto', href: '#contacto' },
];
---

<BaseLayout site={siteConfigConsultorio}>
  <Header site={siteConfigConsultorio} navItems={navItems} />

  <HeroSplit site={siteConfigConsultorio} imagen={galeriaSample[0].src} estilo="superpuesto">
    <Fragment slot="cta">
      <a class="btn btn--primario" href="#servicios">Ver todos los servicios</a>
      <WhatsAppButton
        phone={siteConfigConsultorio.telefonoWhatsApp}
        message={`Hola, quiero agendar una cita en ${siteConfigConsultorio.nombre}`}
        negocioSlug={siteConfigConsultorio.negocioSlug}
        label="Agendar cita por WhatsApp"
        variante="acento"
      />
    </Fragment>
  </HeroSplit>

  <Historia historia={historiaSample} nombreNegocio={siteConfigConsultorio.nombre} fondoAlterno revealFoto="escala" />

  <ServiciosTabs
    categorias={serviciosSample}
    phone={siteConfigConsultorio.telefonoWhatsApp}
    negocioSlug={siteConfigConsultorio.negocioSlug}
  />

  <Testimonials testimonios={testimoniosSample} carrusel fondoSolido />

  <LocationMap site={siteConfigConsultorio} horarios={horariosSample} />

  <ContactForm site={siteConfigConsultorio} productoLabel="Especialidad de interés" />

  <Footer site={siteConfigConsultorio} />

  <FloatingWhatsApp
    phone={siteConfigConsultorio.telefonoWhatsApp}
    message={`Hola, quiero agendar una cita en ${siteConfigConsultorio.nombre}`}
    negocioSlug={siteConfigConsultorio.negocioSlug}
  />
</BaseLayout>
