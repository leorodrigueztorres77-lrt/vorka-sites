---
// Capa 1 — hero dividido (texto + foto lado a lado), alternativa de peso
// visual al Hero de foto grande a pantalla completa. Mismo slot de CTA y
// misma lógica de tracking de WhatsApp que Hero.astro — ninguno de los dos
// contiene lógica específica de vertical, ambos son Capa 1.
import type { SiteConfig } from '@/data/types';

interface Props {
  site: SiteConfig;
  imagen?: string;
  imagenAlt?: string;
  /** Invierte el lado de la foto (por defecto: texto izquierda, foto derecha). */
  invertido?: boolean;
}

// .webp por defecto: estándar de rendimiento (CLAUDE.md) exige WebP/AVIF.
const {
  site,
  imagen = '/images/placeholder-hero.webp',
  imagenAlt = site.nombre,
  invertido = false,
} = Astro.props;
---

<section id="inicio" class:list={['hero-split', { 'hero-split--invertido': invertido }]}>
  <div class="container hero-split__inner">
    <div class="hero-split__texto">
      <h1>{site.nombre}</h1>
      <p class="hero-split__tagline">{site.tagline}</p>
      <div class="hero-split__cta">
        <slot name="cta" />
      </div>
    </div>
    <div class="hero-split__foto">
      <img src={imagen} alt={imagenAlt} loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero-split {
    padding: 4rem 0;
  }

  .hero-split__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media (min-width: 800px) {
    .hero-split__inner {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .hero-split--invertido .hero-split__inner {
      direction: rtl;
    }

    .hero-split--invertido .hero-split__texto,
    .hero-split--invertido .hero-split__foto {
      direction: ltr;
    }
  }

  .hero-split__texto h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-primario);
  }

  .hero-split__tagline {
    font-size: 1.15rem;
    margin-bottom: 2rem;
    opacity: 0.85;
  }

  .hero-split__cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-split__foto img {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: 16px;
  }
</style>
