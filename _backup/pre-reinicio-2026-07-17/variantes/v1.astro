---
// Restaurante — Variante 1 (Capa 2).
// Menú: grid de tarjetas · Hero: foto grande a pantalla completa ·
// Orden: Menú primero.
// demo-personalizer copia esta estructura como punto de partida cuando esta
// es la variante asignada al cliente — el contenido real reemplaza las
// muestras importadas de restaurant.sample.ts.
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Hero from '@/components/common/Hero.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
import Testimonials from '@/components/common/Testimonials.astro';
import LocationMap from '@/components/common/LocationMap.astro';
import ContactForm from '@/components/common/ContactForm.astro';
import Footer from '@/components/common/Footer.astro';

import Menu from '@/components/restaurant/Menu.astro';
import LoyaltyStatus from '@/components/restaurant/LoyaltyStatus.astro';
import CartBar from '@/components/restaurant/CartBar.astro';

import { siteConfig } from '@/data/site.config';
import {
  menuSample,
  galeriaSample,
  horariosSample,
  testimoniosSample,
  estadoFidelizacionSample,
} from '@/data/restaurant.sample';

// El componente de fidelización es opcional: si el negocio no tiene aún
// historial de pedidos suficiente, se omite en la primera entrega (ver
// CLAUDE.md y src/data/types.ts).
const mostrarFidelizacion = Boolean(estadoFidelizacionSample);
---

<BaseLayout site={siteConfig}>
  <Header site={siteConfig} />

  <Hero site={siteConfig}>
    <Fragment slot="cta">
      <WhatsAppButton
        phone={siteConfig.telefonoWhatsApp}
        message={`Hola, quiero hacer un pedido en ${siteConfig.nombre}`}
        negocioSlug={siteConfig.negocioSlug}
        label="Pedir por WhatsApp"
        variante="primario"
      />
    </Fragment>
  </Hero>

  <Menu
    categorias={menuSample}
    phone={siteConfig.telefonoWhatsApp}
    negocioSlug={siteConfig.negocioSlug}
  />

  {mostrarFidelizacion && (
    <section class="section" aria-labelledby="fidelizacion-titulo">
      <div class="container fidelizacion-grid">
        <h2 id="fidelizacion-titulo" class="section-title">Tu progreso como cliente frecuente</h2>
        <LoyaltyStatus estado={estadoFidelizacionSample} />
      </div>
    </section>
  )}

  <Testimonials testimonios={testimoniosSample} fondoSolido fotos={galeriaSample} />

  <LocationMap site={siteConfig} horarios={horariosSample} />

  <ContactForm site={siteConfig} productoLabel="Plato de interés" />

  <Footer site={siteConfig} />

  <CartBar
    phone={siteConfig.telefonoWhatsApp}
    negocioSlug={siteConfig.negocioSlug}
    nombreNegocio={siteConfig.nombre}
  />
</BaseLayout>

<style>
  .fidelizacion-grid {
    max-width: 480px;
    margin: 0 auto;
  }
</style>
